    private async Task SaveRotation()
    {
        if (rotationSchedule == null || string.IsNullOrEmpty(_userId) || string.IsNullOrEmpty(_managerCode)) return;
        if (string.IsNullOrWhiteSpace(newRotationName)) return;

        try
        {
            isBusy = true;

            if (editingRotation != null)
            {
                // Update existing Rotation
                // First, delete old template shifts
                await ShiftsService.DeleteRotationTemplateShiftsAsync(editingRotation.Id!, _managerCode);

                // Update the name (we can't directly update Rotation in the embedded array, so we delete and re-add)
                await SchedulesService.DeleteRotationAsync(rotationSchedule.Id!, _userId, editingRotation.Id!);

                var updatedRotation = new Rotation
                {
                    Id = editingRotation.Id,
                    Name = newRotationName.Trim(),
                    Shifts = new List<RotationShift>()
                };

                var added = await SchedulesService.AddRotationAsync(rotationSchedule.Id!, _userId, updatedRotation);

                // Now create all the template shifts with the RotationId
                foreach (var templateShift in newRotationShifts)
                {
                    templateShift.RotationId = added.Id;
                    templateShift.ManagerCode = _managerCode;
                    templateShift.Username = _username ?? string.Empty;
                    templateShift.ScheduleId = null;
                    await ShiftsService.CreateShiftAsync(templateShift);
                }
            }
            else
            {
                // Create new Rotation
                var rotation = new Rotation
                {
                    Name = newRotationName.Trim(),
                    Shifts = new List<RotationShift>()
                };

                // Add the Rotation metadata to the schedule
                var added = await SchedulesService.AddRotationAsync(rotationSchedule.Id!, _userId, rotation);

                // Now create all the template shifts with the RotationId
                foreach (var templateShift in newRotationShifts)
                {
                    templateShift.RotationId = added.Id;
                    templateShift.ManagerCode = _managerCode;
                    templateShift.Username = _username ?? string.Empty;
                    templateShift.ScheduleId = null;
                    await ShiftsService.CreateShiftAsync(templateShift);
                }
            }

            await LoadSchedules();
            // Refresh reference to updated schedule
            rotationSchedule = schedules.FirstOrDefault(s => s.Id == rotationSchedule.Id);
            // Refresh counts so the selection list reflects the newly saved shifts
            await RefreshRotationShiftCountsAsync(rotationSchedule);
            showCreateRotation = false;
            showRotationModal = false;
            showRotationSelectionModal = true;
            editingRotation = null;
            newRotationName = string.Empty;
            newRotationShifts.Clear();
            originalRotationName = string.Empty;
            originalRotationShifts.Clear();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving rotation");
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task DeleteRotation(Rotation ww)
    {
        if (rotationSchedule == null || string.IsNullOrEmpty(_userId) || string.IsNullOrEmpty(_managerCode) || ww == null) return;

        try
        {
            isBusy = true;
            // Delete all template shifts associated with this Rotation
            await ShiftsService.DeleteRotationTemplateShiftsAsync(ww.Id!, _managerCode);

            // Delete the Rotation metadata from the schedule
            await SchedulesService.DeleteRotationAsync(rotationSchedule.Id!, _userId, ww.Id!);

            await LoadSchedules();
            rotationSchedule = schedules.FirstOrDefault(s => s.Id == rotationSchedule.Id);
            // Refresh counts so the selection list no longer shows the deleted Rotation's shifts
            await RefreshRotationShiftCountsAsync(rotationSchedule);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting rotation");
        }
        finally
        {
            isBusy = false;
        }
    }

