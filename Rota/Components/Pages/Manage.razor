@page "/manage"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Rota.Models
@using System.Globalization
@using Rota.Services
@using Rota.Components
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "manager,admin")]
@inject ISchedulesService SchedulesService
@inject IShiftsService ShiftsService
@inject IUserService UserService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject Microsoft.Extensions.Logging.ILogger<Manage> Logger
@inject IAbsencesService AbsencesService
@inject IWorkerTypesService WorkerTypesService
@inject IJSRuntime JS

<div class="container my-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex align-items-center mb-4">
                <div class="me-auto">
                    <h4 class="mb-0">Manage Schedules</h4>
                    <small class="manage-subtitle">Create and manage your work schedules</small>
                </div>
                <button class="btn btn-primary" @onclick="OpenCreateModal">
                    <span class="me-1">+</span> New Schedule
                </button>
            </div>

            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (schedules.Count == 0)
            {
                <div class="alert alert-info">
                    <strong>No schedules yet.</strong> Create your first schedule to get started.
                </div>
            }
            else
            {
                <div class="schedule-list">
                    @foreach (var schedule in schedules)
                    {
                        <div class="schedule-card @(schedule.IsDefault ? "schedule-card-default" : "")">
                            <div class="schedule-card-body">
                                <div class="schedule-card-title">
                                    @schedule.Name
                                    @if (schedule.IsDefault)
                                    {
                                        <span class="badge bg-primary ms-2">Default</span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(schedule.Description))
                                {
                                    <div class="schedule-card-desc">@schedule.Description</div>
                                }
                                <div class="schedule-card-meta">Created @schedule.CreatedAt.ToLocalTime().ToString("g")</div>
                            </div>
                            <div class="schedule-card-actions">
                                @if (!schedule.IsDefault)
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="(() => SetAsDefault(schedule))">
                                        Set Default
                                    </button>
                                }
                                <button class="btn btn-sm btn-outline-secondary" @onclick="(() => ViewInCalendar(schedule))">
                                    Calendar
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="(() => OpenRotationsModal(schedule))">
                                    Rotations
                                </button>
                                <button class="btn btn-sm btn-outline-warning" @onclick="(() => OpenEditModal(schedule))">
                                    Edit
                                </button>
                                @if (schedules.Count > 1)
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="(() => OpenDeleteConfirm(schedule))">
                                        Delete
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@* Rotation selection modal *@
@if (showRotationSelectionModal && rotationSchedule != null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Rotations - @rotationSchedule.Name</h5>
                    <button type="button" class="btn-close" @onclick="CloseRotationSelectionModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <button class="btn btn-primary w-100" @onclick="OpenCreateRotation">
                            <span class="me-2">+</span> Create New Rotation
                        </button>
                    </div>

                    @if (rotationSchedule.Rotations == null || rotationSchedule.Rotations.Count == 0)
                    {
                        <div class="alert alert-info">No rotation templates exist yet. Create one to get started.</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var ww in rotationSchedule.Rotations)
                            {
                                <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" style="cursor: pointer;" @onclick="(() => OpenEditRotation(ww))">
                                    <div>
                                        <div class="fw-bold">@ww.Name</div>
                                        <div class="text-muted small">@(rotationShiftCounts.GetValueOrDefault(ww.Id ?? "", 0)) shift(s)</div>
                                    </div>
                                    @* Removed inline Edit badge — clicking the list item opens the edit modal *@
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseRotationSelectionModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@* Rotation edit modal *@
@if (showRotationModal && rotationSchedule != null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered ww-modal-dialog modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingRotation == null ? "Create New Rotation" : "Edit Rotation") — @rotationSchedule.Name</h5>
                    <button type="button" class="btn-close" @onclick="CloseRotationModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (showCreateRotation)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Rotation Name</label>
                            <input class="form-control" @bind="newRotationName" @bind:after="OnRotationChanged" />
                        </div>

                        <div class="mb-2">
                            <strong>Shifts</strong>
                            <div class="text-muted small">Click a day to add shifts. Click an existing shift to edit it.</div>
                        </div>

                        @* Week view for adding shifts to weekdays *@
                        <div class="week-grid mb-3">
                            @{
                                var today = DateOnly.FromDateTime(DateTime.Today);
                                var firstDay = CultureInfo.CurrentCulture.DateTimeFormat.FirstDayOfWeek;
                                var diff = ((int)today.DayOfWeek - (int)firstDay + 7) % 7;
                                var start = today.AddDays(-diff);
                            }
                            @foreach (var d in Enumerable.Range(0, 7).Select(i => start.AddDays(i)))
                            {
                                var dow = d.DayOfWeek;
                                <div class="week-day-card card p-2" @onclick="(() => BeginCreateShiftForDay(dow))">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div class="fw-bold">@d.ToString("dddd")</div>
                                    </div>
                                    <div class="events">
                                        @foreach (var s in newRotationShifts.Where(s => s.WorkDay == dow).OrderBy(s => s.Start))
                                        {
                                            <div class="shift-item mb-1"
                                                 style="border-left-color:@(s.Color ?? "#1890ff"); background:@(s.Color ?? "#1890ff")18;"
                                                 @onclick:stopPropagation="true" @onclick="(() => EditRotationShift(s))">
                                                <div class="shift-worker-type" style="color:@(s.Color ?? "#1890ff");">
                                                    @* Match the calendar display format: "Title - WorkerType", or just WorkerType when no title is set *@
                                                    @(string.IsNullOrWhiteSpace(s.Title) ? s.WorkerType.ToString() : $"{s.Title} - {s.WorkerType}")
                                                </div>
                                                <div class="shift-time">@(TimeOnly.FromDateTime(s.Start).ToString("HH:mm")) – @(TimeOnly.FromDateTime(s.End).ToString("HH:mm"))</div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                @* Footer: Delete on the left, Cancel + Save on the right *@
                <div class="modal-footer">
                    <div class="me-auto">
                        @if (editingRotation != null)
                        {
                            <button class="btn btn-outline-danger" @onclick="DeleteCurrentRotation" disabled="@isBusy">
                                Delete Rotation
                            </button>
                        }
                    </div>
                    <button class="btn btn-secondary" @onclick="CancelCreateRotation" disabled="@isBusy">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveRotation" disabled="@(!hasRotationChanges || isBusy)">
                        @(isBusy ? "Saving…" : "Save Rotation")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Create/Edit Schedule Modal *@
@if (showModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingSchedule == null ? "Create New Schedule" : "Edit Schedule")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger">@modalError</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Schedule Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="scheduleName" placeholder="e.g. April 2026 Schedule" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description (optional)</label>
                        <textarea class="form-control" rows="3" @bind="scheduleDescription" placeholder="Add a description for this schedule"></textarea>
                    </div>

                    @if (editingSchedule == null || !editingSchedule.IsDefault)
                    {
                        <div class="mb-3 form-check">
                            <input class="form-check-input" type="checkbox" id="setAsDefault" @bind="setAsDefault" />
                            <label class="form-check-label" for="setAsDefault">
                                Set as default schedule
                            </label>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal" disabled="@isBusy">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveSchedule" disabled="@isBusy">
                        @(isBusy ? "Saving..." : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Delete Confirmation Modal *@
@if (showDeleteConfirm && scheduleToDelete != null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Delete Schedule</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDeleteConfirm" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger">@modalError</div>
                    }
                    <p>Are you sure you want to delete the schedule <strong>@scheduleToDelete.Name</strong>?</p>
                    <p class="text-danger mb-0">
                        <strong>Warning:</strong> All shifts, absences, and reminders associated with this schedule will remain but will no longer be grouped under this schedule.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDeleteConfirm" disabled="@isBusy">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteSchedule" disabled="@isBusy">
                        @(isBusy ? "Deleting..." : "Delete Schedule")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Combined Manage Team card: Team Code, Worker Types, Team Members all nested in one card *@
<div class="container my-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <h4 class="mb-0">Manage Team</h4>
            <small class="manage-subtitle">Team code, roles and members for managing your team.</small>

            <hr class="my-3" />

            @* Team Code (nested card) *@
            <div class="card mb-3">
                <div class="card-body p-3">
                    <h6 class="mb-1">🏷️ Team Code</h6>
                    <p class="manage-subtitle small mb-2">Share this code with employees so they can link to your schedule.</p>
                    <div class="d-flex gap-2 align-items-center">
                        <input class="form-control manager-code-input" value="@(_managerCode ?? string.Empty)" readonly onclick="this.select()" />
                        <button class="btn btn-outline-secondary text-nowrap" @onclick="() => CopyManagerCode()" disabled="@codeCopied">@(codeCopied ? "Copied!" : "Copy")</button>
                    </div>
                </div>
            </div>

            <hr class="my-3" />

            @* Worker Types (nested card) *@
            <div class="card mb-3">
                <div class="card-body p-3">
                    <h6 class="mb-1">🏷️ Worker Types</h6>
                    <p class="manage-subtitle small mb-2">Define the roles used when creating shifts for your team. Only you can see and manage these.</p>

                    @if (workerTypes.Count == 0)
                    {
                        <div class="alert alert-info mb-3">No worker types defined yet. Add one below.</div>
                    }
                    else
                    {
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            @foreach (var wt in workerTypes)
                            {
                                <span class="badge bg-secondary d-flex align-items-center gap-1 fs-6 px-3 py-2">
                                    @wt.Name
                                    <button type="button" class="btn-close btn-close-white ms-1" style="font-size: 0.6rem;" aria-label="Remove @wt.Name" @onclick="(() => RemoveWorkerType(wt))" disabled="@isBusy"></button>
                                </span>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(workerTypeError))
                    {
                        <div class="alert alert-danger py-2">@workerTypeError</div>
                    }

                    <div class="d-flex gap-2">
                        <input class="form-control form-control-sm" style="max-width: 240px;" placeholder="New worker type name" @bind="newWorkerTypeName" @bind:event="oninput" @onkeydown="OnWorkerTypeKeyDown" />
                        <button class="btn btn-sm btn-primary" @onclick="AddWorkerType" disabled="@(isBusy || string.IsNullOrWhiteSpace(newWorkerTypeName))">Add</button>
                    </div>
                </div>
            </div>

            <hr class="my-3" />

            @* Team Members (nested card) *@
            <div class="card mb-0">
                <div class="card-body p-3">
                    <h6 class="mb-1">👥 Team Members</h6>
                    <p class="manage-subtitle small mb-2">Employees currently linked to your team.</p>

                    @if (linkedUsers.Count == 0)
                    {
                        <div class="alert alert-info mb-0">No employees are linked to your team yet. Share your team code above.</div>
                    }
                    else
                    {
                        <div class="team-master-detail">
                            <div class="team-member-list">
                                @foreach (var member in linkedUsers)
                                {
                                    <button class="team-member-list-item @(selectedMember?.Username == member.Username ? "active" : "")" @onclick="() => SelectMember(member)">
                                        <span class="team-list-name">@GetMemberFullName(member)</span>
                                        <span class="team-list-occupation">@member.Occupation</span>
                                    </button>
                                }
                            </div>

                            <div class="team-detail-panel">
                                @if (selectedMember is null)
                                {
                                    <div class="team-detail-empty">Select a team member to view their details.</div>
                                }
                                else
                                {
                                    <div class="team-detail-header">
                                        <div class="team-detail-name">@GetMemberFullName(selectedMember)</div>
                                        <div class="team-detail-username text-muted small">@selectedMember.Username</div>
                                    </div>

                                    <div class="team-detail-info-grid mt-3">
                                        <div class="team-detail-field" style="grid-row: 1; grid-column: 1;">
                                            <label class="team-detail-label">Occupation</label>
                                            <div class="d-flex gap-2 align-items-center mt-1">
                                                <select class="form-select form-select-sm" style="min-width:220px;" @bind="selectedMemberOccupation">
                                                    @foreach (var wt in workerTypes)
                                                    {
                                                        <option value="@wt.Name">@wt.Name</option>
                                                    }
                                                    @if (!string.IsNullOrEmpty(selectedMemberOccupation) && !workerTypes.Any(w => w.Name == selectedMemberOccupation))
                                                    {
                                                        <option value="@selectedMemberOccupation">@selectedMemberOccupation (removed)</option>
                                                    }
                                                </select>

                                                <button class="btn btn-sm btn-primary" @onclick="SaveOccupationOnly" disabled="@(!HasOccupationChanged || isBusy)">Save</button>

                                                @if (!string.IsNullOrEmpty(memberOccupationMessage))
                                                {
                                                    <div class="team-detail-message @(memberOccupationError ? "team-detail-message-error" : "team-detail-message-ok") ms-3">@memberOccupationMessage</div>
                                                }
                                            </div>
                                        </div>

                                        <div class="team-detail-field" style="grid-row: 1; grid-column: 2;">
                                            <label class="team-detail-label small mb-1">Max hours / week</label>
                                            <div class="d-flex gap-2 mt-1">
                                                <input type="number" step="0.5" min="0" class="form-control form-control-sm" style="width:120px;" @bind="selectedMemberMaxHours" />
                                                <button class="btn btn-sm btn-primary" @onclick="SaveMaxHoursOnly" disabled="@(!HasMaxHoursChanged || isBusy)">Save</button>
                                            </div>
                                            @if (!string.IsNullOrEmpty(selectedMemberMaxHoursMessage))
                                            {
                                                <div class="team-detail-message @(selectedMemberMaxHoursError ? "team-detail-message-error" : "team-detail-message-ok") mt-2">@selectedMemberMaxHoursMessage</div>
                                            }
                                        </div>

                                        <div class="team-detail-field" style="grid-row: 2; grid-column: 1;">
                                            <label class="team-detail-label">Weekly Availability</label>
                                            @if (selectedMember.Availability.Count == 0)
                                            {
                                                <div class="team-member-no-avail mt-1">No availability set.</div>
                                            }
                                            else
                                            {
                                                <div class="team-member-avail mt-1">
                                                    @foreach (var day in Enum.GetValues<DayOfWeek>())
                                                    {
                                                        var windows = selectedMember.Availability.Where(a => a.DayOfWeek == day).OrderBy(a => a.StartTime).ToList();
                                                        @if (windows.Count > 0)
                                                        {
                                                            <div class="team-avail-row">
                                                                <span class="team-avail-day">@day.ToString()[..3]</span>
                                                                <span class="team-avail-times">@string.Join(", ", windows.Select(w => $"{FormatTime(w.StartTime)}–{FormatTime(w.EndTime)}"))</span>
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                            }
                                        </div>

                                        <div class="team-detail-field" style="grid-row: 2; grid-column: 2;">
                                            <label class="team-detail-label">Upcoming Absences</label>
                                            @{ var memberKey = selectedMember.Id ?? selectedMember.Username ?? string.Empty; upcomingAbsences.TryGetValue(memberKey, out var memberAbsences); }
                                            @if (memberAbsences == null || memberAbsences.Count == 0)
                                            {
                                                <div class="team-member-no-avail mt-1">No upcoming absences.</div>
                                            }
                                            else
                                            {
                                                <div class="list-group mt-1">
                                                    @foreach (var a in memberAbsences)
                                                    {
                                                        <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-start" style="cursor: pointer;" @onclick="(() => OpenEditAbsenceModal(a))" title="Click to edit absence">
                                                            <div>
                                                                <div class="fw-bold">@a.Title</div>
                                                                <div class="team-absence-date small">@a.StartDate.ToLocalTime().ToString("d") – @a.EndDate.AddDays(-1).ToLocalTime().ToString("d")</div>
                                                                @if (!string.IsNullOrEmpty(a.Notes)) { <div class="team-absence-notes small">@a.Notes</div> }
                                                            </div>
                                                            <div class="text-end ms-3 flex-shrink-0">
                                                                @if (a.IsApproved) { <span class="badge bg-success">Approved</span> }
                                                                else if (a.ApprovalState == AbsenceApprovalState.Denied) { <span class="badge bg-danger">Denied</span> }
                                                                else { <span class="badge bg-secondary">Pending</span> }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@* CalendarEditModal for adding shifts to Rotation templates *@
<CalendarEditModal State="rotationModalState"
                   CanManageShifts="true"
                   Employees="employees"
                   LinkedUsers="new List<User>()"
                   ColorChoices="ColorChoices"
                   WorkerTypes="workerTypeNames"
                   OnClose="CloseRotationShiftModal"
                   OnSaveReminder="@(() => Task.CompletedTask)"
                   OnUpdateReminder="@(() => Task.CompletedTask)"
                   OnDeleteReminder="@(() => Task.CompletedTask)"
                   OnSaveShift="SaveRotationShift"
                   OnUpdateShift="@(() => Task.CompletedTask)"
                   OnDeleteShift="DeleteRotationShift"
                   OnDeleteShiftSeries="@(() => Task.CompletedTask)"
                   OnSaveAbsence="@(() => Task.CompletedTask)"
                   OnUpdateAbsence="@(() => Task.CompletedTask)"
                   OnDeleteAbsence="@(() => Task.CompletedTask)" />

@* CalendarEditModal for editing team member absences *@
<CalendarEditModal State="absenceModalState"
                   CanManageShifts="true"
                   Employees="employees"
                   LinkedUsers="linkedUsers"
                   ColorChoices="ColorChoices"
                   WorkerTypes="workerTypeNames"
                   OnClose="CloseAbsenceModal"
                   OnSaveReminder="@(() => Task.CompletedTask)"
                   OnUpdateReminder="@(() => Task.CompletedTask)"
                   OnDeleteReminder="@(() => Task.CompletedTask)"
                   OnSaveShift="@(() => Task.CompletedTask)"
                   OnUpdateShift="@(() => Task.CompletedTask)"
                   OnDeleteShift="@(() => Task.CompletedTask)"
                   OnDeleteShiftSeries="@(() => Task.CompletedTask)"
                   OnSaveAbsence="@(() => Task.CompletedTask)"
                   OnUpdateAbsence="UpdateAbsenceFromManage"
                   OnDeleteAbsence="DeleteAbsenceFromManage" />

@code {
    private List<Schedule> schedules = new();
    private bool isLoading = false;
    private string? _userId;
    private string? _username;
    private string? _managerCode;
    private bool codeCopied = false;

    // Modal state
    private bool showModal = false;
    private bool showDeleteConfirm = false;
    private Schedule? editingSchedule;
    private Schedule? scheduleToDelete;
    private string scheduleName = string.Empty;
    private string? scheduleDescription;
    private bool setAsDefault = false;
    private string? modalError;
    private bool isBusy = false;

    // Rotation management state
    private bool showRotationSelectionModal = false;
    private bool showRotationModal = false;
    private Schedule? rotationSchedule;
    private bool showCreateRotation = false;
    private Rotation? editingRotation = null;
    private string newRotationName = string.Empty;
    private List<Shift> newRotationShifts = new();
    private DayOfWeek newShiftDay = DayOfWeek.Monday;
    private DayOfWeek? createShiftForDay = null;
    private Shift? editingRotationShift = null;
    private CalendarEditModalState rotationModalState = new();
    private CalendarEditModalState absenceModalState = new();
    private List<User> employees = new();
    private readonly string[] ColorChoices = new[] { "#ff4d4f", "#52c41a", "#1890ff", "#fa8c16", "#d3d3d3" };

    // Stores the real template-shift count per Rotation ID, loaded from the shifts collection
    private Dictionary<string, int> rotationShiftCounts = new();

    // Employees linked to the logged-in manager
    private List<User> linkedUsers = new();

    // Cached upcoming absences per user id (team-member panel)
    private Dictionary<string, List<Absence>> upcomingAbsences = new();

    // Cached upcoming absences per schedule id (schedule list panel)
    private Dictionary<string, List<Absence>> scheduleAbsences = new();

    // Currently selected team member in the master/detail panel
    private User? selectedMember = null;
    private string selectedMemberOccupation = "General";
    // Local edit buffer for the selected member's MaxHours value
    private double selectedMemberMaxHours = 0.0;
    private string? memberOccupationMessage;
    private bool memberOccupationError;
    private string? selectedMemberMaxHoursMessage;
    private bool selectedMemberMaxHoursError;

    /// <summary>True when any of the member editable fields differ from the selected member's saved values.</summary>
    private bool HasMemberChanges =>
        selectedMember is not null && (selectedMemberOccupation != selectedMember.Occupation || selectedMemberMaxHours != (selectedMember?.MaxHours ?? 0.0));

    private bool HasOccupationChanged => selectedMember is not null && selectedMemberOccupation != selectedMember.Occupation;

    private bool HasMaxHoursChanged => selectedMember is not null && selectedMemberMaxHours != (selectedMember?.MaxHours ?? 0.0);

    /// <summary>
    /// Returns the member's full name (First + Last). Falls back to DisplayName then Username
    /// when first/last are not set.
    /// </summary>
    private string GetMemberFullName(User? member)
    {
        if (member == null) return string.Empty;
        var first = member.FirstName?.Trim() ?? string.Empty;
        var last = member.LastName?.Trim() ?? string.Empty;
        var full = (first + " " + last).Trim();
        if (!string.IsNullOrWhiteSpace(full)) return full;
        return member.DisplayName ?? member.Username ?? string.Empty;
    }

    

