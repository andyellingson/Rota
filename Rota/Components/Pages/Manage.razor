                return;
            }

            var ok = await UserService.UpdateMaxHoursAsync(selectedMember.Username, selectedMemberMaxHours);
            if (ok)
            {
                selectedMember.MaxHours = selectedMemberMaxHours;
                selectedMemberMaxHoursMessage = "Max hours updated.";
                selectedMemberMaxHoursError = false;
            }
            else
            {
                selectedMemberMaxHoursMessage = "Could not update max hours. Please try again.";
                selectedMemberMaxHoursError = true;
            }
        }
        finally
        {
            isBusy = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _username = user.Identity?.Name ?? string.Empty;

        if (!string.IsNullOrEmpty(_username))
        {
            var caller = await UserService.GetByUsernameAsync(_username);
            _userId = caller?.Id;
            _managerCode = caller?.ManagerCode;

            // Load employees for shift assignment in Rotation templates
            employees = await UserService.GetUsersByRoleAsync(Roles.Employee);

            // Load employees linked to this manager (exclude the manager themselves)
            if (!string.IsNullOrEmpty(_managerCode))
            {
                var allLinked = await UserService.GetLinkedUsersForManagerAsync(_managerCode);
                linkedUsers = allLinked.Where(u => u.Username != _username).ToList();
            }
        }

        await LoadSchedules();
        await LoadWorkerTypesAsync();
    }

    /// <summary>
    /// Loads worker types owned by the current manager.
    /// </summary>
    private async Task LoadWorkerTypesAsync()
    {
        if (string.IsNullOrEmpty(_userId)) return;
        workerTypes = await WorkerTypesService.GetByOwnerAsync(_userId);
    }

    private async Task CopyManagerCode()
    {
        if (string.IsNullOrEmpty(_managerCode)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _managerCode);
            codeCopied = true;
            StateHasChanged();
            await Task.Delay(2000);
            codeCopied = false;
        }
        catch
        {
            // Clipboard API unavailable; user can copy manually from the readonly input
        }
    }

    /// <summary>
    /// Adds a new worker type for the current manager.
    /// </summary>
    private async Task AddWorkerType()
    {
        var name = newWorkerTypeName.Trim();
        if (string.IsNullOrEmpty(name) || string.IsNullOrEmpty(_userId)) return;

        // Prevent duplicates (case-insensitive)
        if (workerTypes.Any(w => w.Name.Equals(name, StringComparison.OrdinalIgnoreCase)))
        {
            workerTypeError = $"'{name}' already exists.";
            return;
        }

        try
        {
            isBusy = true;
            workerTypeError = null;
            await WorkerTypesService.CreateAsync(new WorkerType { Name = name, OwnerId = _userId });
            newWorkerTypeName = string.Empty;
            await LoadWorkerTypesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error adding worker type");
            workerTypeError = "Failed to add worker type. Please try again.";
        }
        finally
        {
            isBusy = false;
        }
    }

    /// <summary>
    /// Removes a worker type scoped to the current manager.
    /// </summary>
    private async Task RemoveWorkerType(WorkerType wt)
    {
        if (string.IsNullOrEmpty(wt.Id) || string.IsNullOrEmpty(_userId)) return;

        try
        {
            isBusy = true;
            workerTypeError = null;
            await WorkerTypesService.DeleteAsync(wt.Id, _userId);
            await LoadWorkerTypesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error removing worker type {Id}", wt.Id);
            workerTypeError = "Failed to remove worker type. Please try again.";
        }
        finally
        {
            isBusy = false;
        }
    }

    /// <summary>
    /// Allows pressing Enter to submit a new worker type name.
    /// </summary>
    private async Task OnWorkerTypeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddWorkerType();
    }

    private async Task LoadSchedules()
    {
        if (string.IsNullOrEmpty(_userId))
        {
            return;
        }

        isLoading = true;
        try
        {
            schedules = await SchedulesService.GetSchedulesForManagerAsync(_userId);

            // Ensure at least one schedule exists
            if (schedules.Count == 0 && !string.IsNullOrEmpty(_username))
            {
                var defaultSchedule = await SchedulesService.GetOrCreateDefaultScheduleAsync(_userId, _username, _managerCode);
                schedules.Add(defaultSchedule);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading schedules");
        }
        finally
        {
            isLoading = false;
        }

        // Load upcoming absences for each schedule after the schedule list is ready
        await LoadScheduleAbsencesAsync();
    }

    /// <summary>
    /// Loads all upcoming absences (next 30 days) for the manager's team and groups them by ScheduleId,
    /// so each schedule row can display its own upcoming absences list.
    /// </summary>
    private async Task LoadScheduleAbsencesAsync()
    {
        scheduleAbsences.Clear();

        if (string.IsNullOrEmpty(_managerCode))
        {
            return;
        }

        try
        {
            var start = DateOnly.FromDateTime(DateTime.Today);
            var end = DateOnly.FromDateTime(DateTime.Today.AddDays(30));

            // Fetch all upcoming absences for this manager's team in one query
            var all = await AbsencesService.GetAbsencesAsync(_managerCode, null, start, end);

            // Group by ScheduleId; absences with no scheduleId are shown under all schedules
            foreach (var absence in all.OrderBy(a => a.StartDate))
            {
                var sid = absence.ScheduleId;

                if (string.IsNullOrEmpty(sid))
                {
                    // No schedule link — add to every schedule so it isn't silently hidden
                    foreach (var schedule in schedules)
                    {
                        if (string.IsNullOrEmpty(schedule.Id))
                        {
                            continue;
                        }

                        if (!scheduleAbsences.ContainsKey(schedule.Id))
                        {
                            scheduleAbsences[schedule.Id] = new List<Absence>();
                        }

                        scheduleAbsences[schedule.Id].Add(absence);
                    }
                }
                else
                {
                    if (!scheduleAbsences.ContainsKey(sid))
                    {
                        scheduleAbsences[sid] = new List<Absence>();
                    }

                    scheduleAbsences[sid].Add(absence);
                }
            }

            // Ensure every schedule has an entry (even if empty) so the UI doesn't fault
            foreach (var schedule in schedules)
            {
                if (!string.IsNullOrEmpty(schedule.Id) && !scheduleAbsences.ContainsKey(schedule.Id))
                {
                    scheduleAbsences[schedule.Id] = new List<Absence>();
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading schedule absences");
        }
    }

    private void OpenCreateModal()
    {
        editingSchedule = null;
        scheduleName = string.Empty;
        scheduleDescription = null;
        setAsDefault = false;
        modalError = null;
        showModal = true;
    }

    private void OpenEditModal(Schedule schedule)
    {
        editingSchedule = schedule;
        scheduleName = schedule.Name;
        scheduleDescription = schedule.Description;
        setAsDefault = schedule.IsDefault;
        modalError = null;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingSchedule = null;
        modalError = null;
    }

    private async Task SaveSchedule()
    {
        modalError = null;

        if (string.IsNullOrWhiteSpace(scheduleName))
        {
            modalError = "Schedule name is required.";
            return;
        }

        if (string.IsNullOrEmpty(_userId) || string.IsNullOrEmpty(_username))
        {
            modalError = "User information is missing.";
            return;
        }

        isBusy = true;
        try
        {
            if (editingSchedule == null)
            {
                // Create new schedule
                var newSchedule = new Schedule
                {
                    Name = scheduleName.Trim(),
                    Description = scheduleDescription?.Trim(),
                    ManagerId = _userId,
                    ManagerUsername = _username,
                    ManagerCode = _managerCode,
                    IsDefault = setAsDefault
                };

                await SchedulesService.CreateScheduleAsync(newSchedule);
            }
            else
            {
                // Update existing schedule
                await SchedulesService.UpdateScheduleAsync(
                    editingSchedule.Id!,
                    _userId,
                    scheduleName.Trim(),
                    scheduleDescription?.Trim(),
                    setAsDefault
                );
            }

            CloseModal();
            await LoadSchedules();
        }
        catch (InvalidOperationException ex)
        {
            modalError = ex.Message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving schedule");
            modalError = "An error occurred while saving the schedule. Please try again.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private void OpenDeleteConfirm(Schedule schedule)
    {
        scheduleToDelete = schedule;
        modalError = null;
        showDeleteConfirm = true;
    }

    private void CloseDeleteConfirm()
    {
        showDeleteConfirm = false;
        scheduleToDelete = null;
        modalError = null;
    }

    private async Task DeleteSchedule()
    {
        if (scheduleToDelete == null || string.IsNullOrEmpty(_userId))
        {
            return;
        }

        isBusy = true;
        modalError = null;
        try
        {
            await SchedulesService.DeleteScheduleAsync(scheduleToDelete.Id!, _userId);
            CloseDeleteConfirm();
            await LoadSchedules();
        }
        catch (InvalidOperationException ex)
        {
            modalError = ex.Message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting schedule");
            modalError = "An error occurred while deleting the schedule. Please try again.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task SetAsDefault(Schedule schedule)
    {
        if (string.IsNullOrEmpty(_userId))
        {
            return;
        }

        try
        {
            await SchedulesService.SetDefaultScheduleAsync(schedule.Id!, _userId);
            await LoadSchedules();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error setting default schedule");
        }
    }

    private void ViewInCalendar(Schedule schedule)
    {
        Navigation.NavigateTo($"/calendar?scheduleId={schedule.Id}");
    }
