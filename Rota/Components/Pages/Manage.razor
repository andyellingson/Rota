    private async Task LoadUpcomingAbsencesForMember(User member)
    {
        if (member == null)
        {
            return;
        }

        var key = member.Id ?? member.Username ?? string.Empty;

        try
        {
            if (string.IsNullOrEmpty(key) || string.IsNullOrEmpty(_managerCode))
            {
                upcomingAbsences[key] = new List<Absence>();
                return;
            }

            var start = DateOnly.FromDateTime(DateTime.Today);
            var end = DateOnly.FromDateTime(DateTime.Today.AddDays(30));
            // Pass null for managerCode so the OR filter in GetAbsencesAsync only matches by userId,
            // preventing other team members' absences from leaking into this member's list.
            var abs = await AbsencesService.GetAbsencesAsync(null, member.Id, start, end);
            upcomingAbsences[key] = abs.OrderBy(a => a.StartDate).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading absences for member {Member}", member.Username);
            upcomingAbsences[key] = new List<Absence>();
        }
    }

