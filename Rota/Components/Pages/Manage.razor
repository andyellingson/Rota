    /// <summary>
    /// Saves approval state and other edits for an absence opened from the Manage page.
    /// Refreshes the absence list for the selected member on success.
    /// </summary>
    private async Task UpdateAbsenceFromManage()
    {
        var absence = absenceModalState.EditingAbsence;
        if (absence?.Id is null) return;

        absenceModalState.IsBusy = true;
        try
        {
            var parsed = DateTime.Parse(absenceModalState.EditAbsenceStartDateUtc, System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.RoundtripKind);
            var startUtc = DateTime.SpecifyKind(parsed, DateTimeKind.Utc);
            var dayCount = Math.Max(1, Math.Min(absenceModalState.EditAbsenceDayCount, 365));
            DateTime endUtc;
            string? startTimeStr = null;
            string? endTimeStr = null;

            if (absenceModalState.EditAbsenceIsPartDay && dayCount == 1)
            {
                var localStartDate = DateOnly.FromDateTime(startUtc.ToLocalTime());
                var localStart = localStartDate.ToDateTime(absenceModalState.EditAbsenceStartTime, DateTimeKind.Local);
                var localEnd = localStartDate.ToDateTime(absenceModalState.EditAbsenceEndTime, DateTimeKind.Local);
                var startUtcPart = DateTime.SpecifyKind(localStart.ToUniversalTime(), DateTimeKind.Utc);
                endUtc = DateTime.SpecifyKind(localEnd.ToUniversalTime(), DateTimeKind.Utc);

                if (endUtc <= startUtcPart)
                {
                    absenceModalState.ModalError = "End time must be after start time";
                    return;
                }

                startUtc = startUtcPart;
                startTimeStr = absenceModalState.EditAbsenceStartTime.ToString("HH:mm");
                endTimeStr = absenceModalState.EditAbsenceEndTime.ToString("HH:mm");
            }
            else
            {
                endUtc = startUtc.AddDays(dayCount);
            }

            // Resolve the target user id from the selected linked user
            var targetUser = linkedUsers.FirstOrDefault(u => u.Id == absenceModalState.EditAbsenceForUsername);
            var targetUserId = targetUser?.Id ?? absenceModalState.EditAbsenceForUsername;

            await AbsencesService.UpdateAbsenceAsync(
                absence.Id,
                absence.Username,
                absenceModalState.EditAbsenceTitle,
                absenceModalState.EditAbsenceNotes,
                startUtc,
                endUtc,
                dayCount,
                absenceModalState.EditAbsenceColor,
                targetUserId,
                targetUserId,
                _managerCode,
                startTimeStr,
                endTimeStr,
                absenceModalState.EditAbsenceApprovalState);

            CloseAbsenceModal();

            // Refresh absence list for the selected member
            if (selectedMember is not null)
                await LoadUpcomingAbsencesForMember(selectedMember);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating absence {Id}", absence.Id);
            absenceModalState.ModalError = "An error occurred while saving. Please try again.";
        }
        finally
        {
            absenceModalState.IsBusy = false;
        }
    }

