    private async Task SaveRotationShift()
    {
        if (!createShiftForDay.HasValue) return;

        if (editingRotationShift != null)
        {
            // Update existing template shift
            editingRotationShift.WorkDay = createShiftForDay.Value;
            // Create a reference date to store times (will be replaced when applying to calendar)
            var refDate = new DateTime(2000, 1, 1, 0, 0, 0, DateTimeKind.Utc);
            editingRotationShift.Start = refDate.Add(rotationModalState.NewShiftStartTime.ToTimeSpan());
            editingRotationShift.End = refDate.Add(rotationModalState.NewShiftEndTime.ToTimeSpan());
            editingRotationShift.Title = string.IsNullOrWhiteSpace(rotationModalState.NewShiftTitle) ? "" : rotationModalState.NewShiftTitle.Trim();
            editingRotationShift.Color = rotationModalState.NewShiftColor;
            editingRotationShift.Notes = rotationModalState.NewShiftNotes;
            editingRotationShift.WorkerType = rotationModalState.NewShiftWorkerType;
            editingRotationShift.AssignedToUserId = string.IsNullOrWhiteSpace(rotationModalState.NewShiftAssignedTo) ? null : rotationModalState.NewShiftAssignedTo;
        }
        else
        {
            // Determine which days to create shifts for based on recurrence
            var daysToCreate = new List<DayOfWeek>();

            switch (rotationModalState.NewShiftRecurrence)
            {
                case ShiftRecurrence.None:
                    daysToCreate.Add(createShiftForDay.Value);
                    break;

                case ShiftRecurrence.Daily:
                    // All 7 days
                    daysToCreate.AddRange(new[]
                    {
                        DayOfWeek.Sunday, DayOfWeek.Monday, DayOfWeek.Tuesday,
                        DayOfWeek.Wednesday, DayOfWeek.Thursday, DayOfWeek.Friday,
                        DayOfWeek.Saturday
                    });
                    break;

                case ShiftRecurrence.Workdays:
                    // Monday through Friday
                    daysToCreate.AddRange(new[]
                    {
                        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
                        DayOfWeek.Thursday, DayOfWeek.Friday
                    });
                    break;

                case ShiftRecurrence.Weekends:
                    // Saturday and Sunday
                    daysToCreate.AddRange(new[] { DayOfWeek.Saturday, DayOfWeek.Sunday });
                    break;
            }

            // Create a template shift for each day
            // Note: RotationId will be set when SaveRotation is called
            foreach (var day in daysToCreate)
            {
                // Use a reference date to store the time (2000-01-01)
                var refDate = new DateTime(2000, 1, 1, 0, 0, 0, DateTimeKind.Utc);
                var start = refDate.Add(rotationModalState.NewShiftStartTime.ToTimeSpan());
                var end = refDate.Add(rotationModalState.NewShiftEndTime.ToTimeSpan());

                newRotationShifts.Add(new Shift
                {
                    Id = null,
                    WorkDay = day,
                    Start = start,
                    End = end,
                    Title = string.IsNullOrWhiteSpace(rotationModalState.NewShiftTitle) ? "" : rotationModalState.NewShiftTitle.Trim(),
                    Color = rotationModalState.NewShiftColor,
                    Notes = rotationModalState.NewShiftNotes,
                    WorkerType = rotationModalState.NewShiftWorkerType,
                    AssignedToUserId = string.IsNullOrWhiteSpace(rotationModalState.NewShiftAssignedTo) ? null : rotationModalState.NewShiftAssignedTo,
                    Username = _username ?? string.Empty,
                    ManagerCode = _managerCode,
                    ScheduleId = null, // Template shifts don't have ScheduleId
                    RotationId = null  // Will be set when SaveRotation creates the Rotation
                });
            }
        }

        CloseRotationShiftModal();
        StateHasChanged(); // Trigger change detection
        await Task.CompletedTask;
    }

    private async Task DeleteRotationShift()
    {
        if (editingRotationShift != null)
        {
            // Remove the shift from the template
