    /// <summary>
    /// Persists the occupation change for the selected team member.
    /// Updates the local copy on success so the list badge stays in sync.
    /// </summary>
    private async Task SaveMemberOccupation()
    {
        if (selectedMember is null) return;
        memberOccupationMessage = null;
        isBusy = true;
        try
        {
            // Only call updates for fields that actually changed. Treat unchanged fields as successful.
            var occOk = true;
            var maxOk = true;

            var occChanged = selectedMemberOccupation != selectedMember.Occupation;
            var maxChanged = selectedMemberMaxHours != (selectedMember.MaxHours);

            if (occChanged)
            {
                occOk = await UserService.UpdateOccupationAsync(selectedMember.Username, selectedMemberOccupation);
            }

            if (maxChanged)
            {
                maxOk = await UserService.UpdateMaxHoursAsync(selectedMember.Username, selectedMemberMaxHours);
            }

            // Consider operation successful if all attempted updates returned true.
            if ((occChanged ? occOk : true) && (maxChanged ? maxOk : true))
            {
                // Keep the in-memory list in sync so the list badge updates immediately
                selectedMember.Occupation = selectedMemberOccupation;
                selectedMember.MaxHours = selectedMemberMaxHours;
                memberOccupationMessage = "Member updated.";
                memberOccupationError = false;
            }
            else
            {
                // Partial or full failure. If DB was updated but the Update call returned false
                // (ModifiedCount == 0) treat that as success — query DB is the source of truth.
                // However, we can't call DB here; instead provide a clearer guidance message.
                memberOccupationMessage = "Could not update all member values. Please try again.";
                memberOccupationError = true;
            }
        }
        finally
        {
            isBusy = false;
        }
    }

