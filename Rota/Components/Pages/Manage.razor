    /// <summary>
    /// Queries the shifts collection for each Rotation in the given schedule and
    /// populates rotationShiftCounts so the selection list shows accurate counts.
    /// </summary>
    private async Task RefreshRotationShiftCountsAsync(Schedule? schedule)
    {
        rotationShiftCounts.Clear();

        if (schedule?.Rotations == null || string.IsNullOrEmpty(_managerCode)) return;

        foreach (var ww in schedule.Rotations)
        {
            if (string.IsNullOrEmpty(ww.Id)) continue;

            try
            {
                var shifts = await ShiftsService.GetRotationTemplateShiftsAsync(ww.Id, _managerCode);
                rotationShiftCounts[ww.Id] = shifts.Count;
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error loading shift count for Rotation {RotationId}", ww.Id);
                rotationShiftCounts[ww.Id] = 0;
            }
        }
    }

