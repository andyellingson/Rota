    private bool CheckRotationChanges()
    {
        // For new rotations, enable save if name is not empty
        if (editingRotation == null)
        {
            return !string.IsNullOrWhiteSpace(newRotationName);
        }

        // For existing rotations, check if name or shifts changed
        if (newRotationName != originalRotationName)
        {
            return true;
        }

        // Check if shifts changed (count, content, or order)
        if (newRotationShifts.Count != originalRotationShifts.Count)
        {
            return true;
        }

        // Deep comparison of shifts
        for (int i = 0; i < newRotationShifts.Count; i++)
        {
            var current = newRotationShifts[i];
            var original = originalRotationShifts.FirstOrDefault(s => s.Id == current.Id);

            if (original == null ||
                current.WorkDay != original.WorkDay ||
                current.Start != original.Start ||
                current.End != original.End ||
                current.Title != original.Title ||
                current.Color != original.Color ||
                current.Notes != original.Notes ||
                current.WorkerType != original.WorkerType ||
                current.AssignedToUserId != original.AssignedToUserId)
            {
                return true;
            }
        }

        return false;
    }

