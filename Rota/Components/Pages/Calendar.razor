    /// <summary>
    /// Load reminders when the component initializes. The page-level [Authorize] attribute
    /// ensures the user is authenticated before reaching this component, so we rely on the
    /// browser's session cookie (credentials: same-origin) for API auth rather than
    /// querying HttpContextAuthenticationStateProvider, which is null during the SignalR
    /// interactive phase.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _username = user.Identity?.Name ?? string.Empty;

        if (!string.IsNullOrEmpty(_username))
        {
            var caller = await UserService.GetByUsernameAsync(_username);
            _userId = caller?.Id;

            canManageShifts = user.IsInRole(Roles.Manager) || user.IsInRole(Roles.Admin);
            if (canManageShifts)
            {
                _managerCode = caller?.ManagerCode;
                employees = await UserService.GetUsersByRoleAsync(Roles.Employee);
            }
            else if (user.IsInRole(Roles.Employee) && !string.IsNullOrEmpty(caller?.ManagerUsername))
            {
                var manager = await UserService.GetByUsernameAsync(caller.ManagerUsername);
                _managerCode = manager?.ManagerCode;
            }

            var managerUsernameForLinkedUsers = canManageShifts
                ? caller?.Username
                : caller?.ManagerUsername;

            if (!string.IsNullOrEmpty(managerUsernameForLinkedUsers))
            {
                linkedUsers = await UserService.GetLinkedUsersForManagerAsync(managerUsernameForLinkedUsers);
            }

            if (caller is not null && !linkedUsers.Any(u => u.Username == caller.Username))
            {
                linkedUsers.Add(caller);
                linkedUsers = linkedUsers
                    .OrderBy(u => u.DisplayName ?? u.Username)
                    .ThenBy(u => u.Username)
                    .ToList();
            }

            newReminderForUsername = _username;
            newAbsenceForUsername = _userId;

            // Load schedules for all roles
            if (!string.IsNullOrEmpty(_userId))
            {
                await LoadSchedules();
            }
        }

        await LoadReminders();
    }

    /// <summary>
    /// Load available schedules.
    /// Managers see all schedules they own; employees see only schedules they
    /// have at least one shift assigned to them on.
    /// </summary>
    private async Task LoadSchedules()
    {
        if (string.IsNullOrEmpty(_userId))
        {
            return;
        }

        try
        {
            if (canManageShifts)
            {
                availableSchedules = await SchedulesService.GetSchedulesForManagerAsync(_userId);

                // Ensure at least one schedule exists for managers
                if (availableSchedules.Count == 0 && !string.IsNullOrEmpty(_username))
                {
                    var defaultSchedule = await SchedulesService.GetOrCreateDefaultScheduleAsync(_userId, _username, _managerCode);
                    availableSchedules.Add(defaultSchedule);
                }
            }
            else
            {
                // Employees: find every schedule they are assigned to across all managers
                var scheduleIds = await ShiftService.GetDistinctScheduleIdsForUserAsync(_userId);
                if (scheduleIds.Count > 0)
                {
                    availableSchedules = await SchedulesService.GetSchedulesByIdsAsync(scheduleIds);
                }
            }

            // Set initial schedule selection
            if (!string.IsNullOrEmpty(QueryScheduleId))
            {
                selectedScheduleId = QueryScheduleId;
            }
            else
            {
                var defaultSchedule = availableSchedules.FirstOrDefault(s => s.IsDefault) ?? availableSchedules.FirstOrDefault();
                selectedScheduleId = defaultSchedule?.Id;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading schedules");
        }
    }

