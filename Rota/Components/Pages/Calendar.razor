    /// <summary>
    /// Returns the date for the start of the week containing the provided date (based on culture).
    /// </summary>
    private DateOnly StartOfWeek(DateOnly date)
    {
        var fdow = CultureInfo.CurrentCulture.DateTimeFormat.FirstDayOfWeek;
        var diff = ((int)date.DayOfWeek - (int)fdow + 7) % 7;
        return date.AddDays(-diff);
    }

    /// <summary>
    /// Builds a matrix of weeks for the month view. Each inner list contains seven DateOnly entries.
    /// </summary>
    private List<List<DateOnly>> GetMonthMatrix(DateOnly forDate)
    {
        var result = new List<List<DateOnly>>();
        try
        {
            var firstOfMonth = new DateOnly(forDate.Year, forDate.Month, 1);
            var start = StartOfWeek(firstOfMonth);
            // Show 6 weeks to accommodate months that span six calendar rows
            for (int week = 0; week < 6; week++)
            {
                var weekRow = new List<DateOnly>();
                for (int d = 0; d < 7; d++)
                {
                    weekRow.Add(start.AddDays(week * 7 + d));
                }
                result.Add(weekRow);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error building month matrix for {Date}", forDate);
        }
        return result;
    }

