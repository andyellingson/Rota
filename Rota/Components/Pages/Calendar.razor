        }
        finally
        {
            isBusy = false;
        }
    }

    /// <summary>
    /// Saves a new Shift to the server.
    /// </summary>
    private async Task SaveShift()
    {
        modalError = null;
        if (selectedDate is null) return;

        if (string.IsNullOrWhiteSpace(newShiftTitle))
        {
            modalError = "Shift title is required";
            return;
        }

        try
        {
            isBusy = true;

            // Generate a shared SeriesId when creating a repeating shift
            Guid? seriesId = newShiftRecurrence != ShiftRecurrence.None ? Guid.NewGuid() : null;

            async Task CreateShiftForDate(DateOnly d)
            {
                var startLocal = d.ToDateTime(newShiftStartTime, DateTimeKind.Local);
                var endLocal = d.ToDateTime(newShiftEndTime, DateTimeKind.Local);
                var startUtc = startLocal.ToUniversalTime();
                var endUtc = endLocal.ToUniversalTime();

                if (endUtc <= startUtc)
                {
                    modalError = "End time must be after start time";
                    return;
                }

                var shift = new Shift
                {
                    Username = _username,
                    Start = startUtc,
                    End = endUtc,
                    Title = newShiftTitle,
                    Notes = newShiftNotes,
                    WorkerType = newShiftWorkerType,
                    Color = newShiftColor,
                    AssignedToUserId = string.IsNullOrEmpty(newShiftAssignedTo) ? null : newShiftAssignedTo,
                    ManagerCode = _managerCode,
                    SeriesId = seriesId
                };
                await ShiftService.CreateShiftAsync(shift);
            }

            if (newShiftRecurrence == ShiftRecurrence.None)
            {
                await CreateShiftForDate(selectedDate.Value);
            }
            else
            {
                var monthStart = new DateOnly(selectedDate.Value.Year, selectedDate.Value.Month, 1);
                var monthEnd = monthStart.AddMonths(1).AddDays(-1);
                for (var day = monthStart; day <= monthEnd; day = day.AddDays(1))
                {
                    if (modalError is not null) break;
                    if (newShiftRecurrence == ShiftRecurrence.Daily)
                    {
                        await CreateShiftForDate(day);
                    }
                    else if (newShiftRecurrence == ShiftRecurrence.Workdays)
                    {
                        var dow = day.DayOfWeek;
                        if (dow >= DayOfWeek.Monday && dow <= DayOfWeek.Friday)
                            await CreateShiftForDate(day);
                    }
                    else if (newShiftRecurrence == ShiftRecurrence.Weekends)
                    {
                        var dow = day.DayOfWeek;
                        if (dow == DayOfWeek.Saturday || dow == DayOfWeek.Sunday)
                            await CreateShiftForDate(day);
                    }
                }
            }

            if (modalError is null)
            {
                CloseModal();
                await LoadReminders();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving Shift");
            modalError = "An error occurred. Please try again.";
        }
        finally
        {
            isBusy = false;
        }
    }

