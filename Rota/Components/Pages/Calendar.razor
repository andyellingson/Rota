@page "/calendar"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Globalization
@using Rota.Models
@using Rota.Services
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject NavigationManager Navigation
@inject Microsoft.Extensions.Logging.ILogger<Calendar> Logger
@inject IRemindersService RemindersService
@inject IShiftsService ShiftService
@inject IAbsencesService AbsenceService
@inject IUserService UserService
@inject ISchedulesService SchedulesService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider


<div class="calendar-card card shadow-sm my-4">
    <div class="card-body">
        <div class="d-flex align-items-center mb-3">
            <div class="me-auto">
                <h4 class="mb-0">Calendar</h4>
                <small class="text-muted">View and browse your schedule</small>
            </div>

            @if (availableSchedules.Count > 0)
            {
                <div class="me-2">
                    <select class="form-select form-select-sm" @bind="selectedScheduleId" @bind:after="OnScheduleChanged">
                        @foreach (var schedule in availableSchedules)
                        {
                            <option value="@schedule.Id">@schedule.Name</option>
                        }
                    </select>
                </div>
            }

            <div class="btn-group me-2" role="group" aria-label="Event filters">
                <input type="checkbox" class="btn-check" id="filter-shifts" @bind="showShifts" @bind:after="FilterChanged" autocomplete="off" >
                <label class="btn btn-outline-primary btn-sm" for="filter-shifts">Shifts</label>

                <input type="checkbox" class="btn-check" id="filter-absences" @bind="showAbsences" @bind:after="FilterChanged" autocomplete="off" >
                <label class="btn btn-outline-warning btn-sm" for="filter-absences">Absences</label>

                <input type="checkbox" class="btn-check" id="filter-reminders" @bind="showReminders" @bind:after="FilterChanged" autocomplete="off" >
                <label class="btn btn-outline-info btn-sm" for="filter-reminders">Reminders</label>
            </div>

            <div class="btn-group me-2" role="group" aria-label="View mode">
                <button class="btn btn-outline-primary" @onclick="(() => SetView(ViewMode.Week))" aria-pressed="@(view == ViewMode.Week)">Week</button>
                <button class="btn btn-outline-primary" @onclick="(() => SetView(ViewMode.Month))" aria-pressed="@(view == ViewMode.Month)">Month</button>
            </div>

            <div class="btn-group" role="group" aria-label="Navigation">
                <button class="btn btn-light" @onclick="Prev">‹</button>
                <button class="btn btn-light" @onclick="Next">›</button>
            </div>
        </div>

        @if (view == ViewMode.Month)
        {
            <div class="calendar-month">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <strong>@current.ToString("MMMM yyyy", CultureInfo.CurrentCulture)</strong>
                    <div class="text-muted small">Week starts on @CultureInfo.CurrentCulture.DateTimeFormat.FirstDayOfWeek</div>
                </div>

                <div class="calendar-grid">
                    @foreach (var name in DayNames)
                    {
                        <div class="calendar-grid-header">@name</div>
                    }

                    @foreach (var week in GetMonthMatrix(current))
                    {
                        foreach (var day in week)
                        {
                            var other = day.Month != current.Month;
                            var isToday = day == DateOnly.FromDateTime(DateTime.Today);
                            <div class="day-cell @(other ? "other-month" : "") @(isToday ? "today" : "")" @onclick="(() => OpenDayModal(day))">
                                <div class="day-number">@day.Day</div>
                                <div class="events events-overlay">
                                    @foreach (var item in GetSortedDayItems(day))
                                    {
                                        if (item.Shift is { } s)
                                        {
                                            <div class="shift-item mb-1" style="border-left-color: @(s.Color ?? "#1890ff");" @onclick:stopPropagation="true" @onclick="(() => { if (canManageShifts) OpenEditShiftModal(s); })">
                                                <div class="shift-worker-type" style="color: @(s.Color ?? "#1890ff");">@GetShiftDisplayTitle(s)</div>
                                                <div class="shift-time">@s.Start.ToLocalTime().ToString("t") – @s.End.ToLocalTime().ToString("t")</div>
                                                @if (!string.IsNullOrEmpty(s.AssignedToUserId))
                                                {
                                                    <div class="shift-assigned">@GetEmployeeDisplayNameById(s.AssignedToUserId)</div>
                                                }
                                            </div>
                                        }
                                        else if (item.Absence is { } ab)
                                        {
                                            <div class="absence-item mb-1" style="background-color: @(ab.Color ?? "#fa8c16");" @onclick:stopPropagation="true" @onclick="(() => OpenEditAbsenceModal(ab))">
                                                <div class="d-flex w-100">
                                                    <div class="absence-left text-start text-truncate">@GetEmployeeDisplayNameById(ab.AssignedToUserId)</div>
                                                    <div class="absence-right text-end text-truncate">@ab.Title</div>
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(ab.StartTime) && !string.IsNullOrWhiteSpace(ab.EndTime) && ab.DayCount == 1)
                                                {
                                                    if (TimeOnly.TryParse(ab.StartTime, CultureInfo.CurrentCulture, out var sst) && TimeOnly.TryParse(ab.EndTime, CultureInfo.CurrentCulture, out var eet))
                                                    {
                                                        <div class="absence-time small mt-1">@sst.ToString("t", CultureInfo.CurrentCulture) – @eet.ToString("t", CultureInfo.CurrentCulture)</div>
                                                    }
                                                }
                                            </div>
                                        }
                                        else if (item.Reminder is { } reminder)
                                        {
                                            <ReminderItem Reminder="reminder" OnEdit="OpenEditReminderModal" />
                                        }
                                    }
                                </div>
                            </div>
                        }
                    }

                </div>
            </div>
        }
        else
        {
            <div class="calendar-week">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <strong>Week of @StartOfWeek(current).ToString("d", CultureInfo.CurrentCulture)</strong>
                </div>

                <div class="week-grid">
                    @foreach (var d in Enumerable.Range(0, 7).Select(i => StartOfWeek(current).AddDays(i)))
                    {
                        var isToday = d == DateOnly.FromDateTime(DateTime.Today);
                        <div class="week-day-card card me-2" @onclick="(() => OpenDayModal(d))">
                            <div class="card-body p-2">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-bold">@d.ToString("ddd", CultureInfo.CurrentCulture)</div>
                                        <div class="text-muted small">@d.ToString("d", CultureInfo.CurrentCulture)</div>
                                    </div>
                                    @if (isToday)
                                    {
                                        <span class="badge bg-primary">Today</span>
                                    }
                                </div>
                                <div class="mt-2 events events-overlay">
                                    @foreach (var item in GetSortedDayItems(d))
                                    {
                                        if (item.Shift is { } s)
                                        {
                                            <div class="shift-item mb-1" style="border-left-color: @(s.Color ?? "#1890ff");" @onclick:stopPropagation="true" @onclick="(() => { if (canManageShifts) OpenEditShiftModal(s); })">
                                                <div class="shift-worker-type" style="color: @(s.Color ?? "#1890ff");">@GetShiftDisplayTitle(s)</div>
                                                <div class="shift-time">@s.Start.ToLocalTime().ToString("t") – @s.End.ToLocalTime().ToString("t")</div>
                                                @if (!string.IsNullOrEmpty(s.AssignedToUserId))
                                                {
                                                    <div class="shift-assigned">@GetEmployeeDisplayNameById(s.AssignedToUserId)</div>
                                                }
                                            </div>
                                        }
                                        else if (item.Absence is { } ab)
                                        {
                                            <div class="absence-item mb-1" style="background-color: @(ab.Color ?? "#fa8c16");" @onclick:stopPropagation="true" @onclick="(() => OpenEditAbsenceModal(ab))">
                                                <div class="d-flex w-100">
                                                    <div class="absence-left text-start text-truncate">@GetEmployeeDisplayNameById(ab.AssignedToUserId)</div>
                                                    <div class="absence-right text-end text-truncate">@ab.Title</div>
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(ab.StartTime) && !string.IsNullOrWhiteSpace(ab.EndTime) && ab.DayCount == 1)
                                                {
                                                    if (TimeOnly.TryParse(ab.StartTime, CultureInfo.CurrentCulture, out var sst) && TimeOnly.TryParse(ab.EndTime, CultureInfo.CurrentCulture, out var eet))
                                                    {
                                                        <div class="absence-time small mt-1">@sst.ToString("t", CultureInfo.CurrentCulture) – @eet.ToString("t", CultureInfo.CurrentCulture)</div>
                                                    }
                                                }
                                            </div>
                                        }
                                        else if (item.Reminder is { } reminder)
                                        {
                                            <ReminderItem Reminder="reminder" OnEdit="OpenEditReminderModal" />
                                        }
                                    }
                                </div>
                                <button class="btn btn-sm btn-outline-secondary w-100 mt-1" @onclick:stopPropagation="true" @onclick="(() => OpenAddReminderModal(d))">+ Add</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@* Day detail modal – expanded view for a single day *@
@if (showDayModal)
{
    var detailShifts = GetShiftsForDay(dayModalDate).OrderBy(s => s.Start).ToList();
    var detailReminders = GetRemindersForDay(dayModalDate).OrderBy(r => r.ReminderDateTime).ToList();
    var detailAbsences = GetAbsencesForDay(dayModalDate).OrderBy(a => a.StartDate).ToList();
    var isToday = dayModalDate == DateOnly.FromDateTime(DateTime.Today);
    var totalItems = detailShifts.Count + detailAbsences.Count + detailReminders.Count;

    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable" role="document">
            <div class="modal-content day-modal-content">

                @* ── Modal header ──────────────────────────────────────────── *@
                <div class="modal-header day-modal-header">
                    <div class="d-flex align-items-center gap-3">
                        @* Date badge showing day number *@
                        <div class="day-modal-date-badge @(isToday ? "day-modal-date-badge--today" : "")">
                            <span class="day-modal-date-badge-num">@dayModalDate.Day</span>
                            <span class="day-modal-date-badge-month">@dayModalDate.ToString("MMM", CultureInfo.CurrentCulture)</span>
                        </div>
                        <div>
                            <h5 class="modal-title mb-0 fw-bold">
                                @dayModalDate.ToString("dddd", CultureInfo.CurrentCulture)
                                @if (isToday)
                                {
                                    <span class="badge bg-primary ms-2" style="font-size:0.6rem;vertical-align:middle;">Today</span>
                                }
                            </h5>
                            <small class="text-muted">@dayModalDate.ToString("d MMMM yyyy", CultureInfo.CurrentCulture)</small>
                        </div>
                    </div>

                    @* Action buttons + close *@
                    <div class="d-flex gap-2 align-items-center ms-auto">
                        @if (canManageShifts)
                        {
                            <button class="btn btn-sm btn-primary day-modal-action-btn" @onclick="AddShiftFromDayModal" title="Add a shift">
                                <span class="day-modal-btn-icon">＋</span> Shift
                            </button>
                        }
                        <button class="btn btn-sm btn-warning text-dark day-modal-action-btn" @onclick="AddAbsenceFromDayModal" title="Add an absence">
                            <span class="day-modal-btn-icon">＋</span> Absence
                        </button>
                        <button class="btn btn-sm btn-outline-secondary day-modal-action-btn" @onclick="AddReminderFromDayModal" title="Add a reminder">
                            <span class="day-modal-btn-icon">＋</span> Reminder
                        </button>
                        <button type="button" class="btn-close ms-1" @onclick="CloseDayModal" aria-label="Close"></button>
                    </div>
                </div>

                @* ── Apply WorkWeek template bar (managers only) ────────────── *@
                @if (canManageShifts)
                {
                    var wwSel = availableSchedules.FirstOrDefault(s => s.Id == selectedScheduleId);
                    if (wwSel?.WorkWeeks?.Count > 0)
                    {
                        <div class="day-modal-template-bar">
                            <div class="day-modal-template-bar-label">
                                <span class="day-modal-section-icon day-modal-section-icon--template">📋</span>
                                <span class="day-modal-template-bar-title">Apply Template</span>
                            </div>
                            <div class="d-flex align-items-center gap-2 flex-wrap mt-2">
                                <select class="form-select form-select-sm day-modal-template-select" @bind="dayModalSelectedWorkWeekId">
                                    <option value="">— Select WorkWeek —</option>
                                    @foreach (var ww in wwSel.WorkWeeks)
                                    {
                                        <option value="@ww.Id">@ww.Name</option>
                                    }
                                </select>
                                <div class="d-flex align-items-center gap-1">
                                    <input type="date" class="form-control form-control-sm day-modal-date-input"
                                           @bind="workWeekRangeStart" @bind:format="yyyy-MM-dd" />
                                    <span class="text-muted small px-1">→</span>
                                    <input type="date" class="form-control form-control-sm day-modal-date-input"
                                           @bind="workWeekRangeEnd" @bind:format="yyyy-MM-dd" />
                                </div>
                                <button class="btn btn-sm btn-primary" @onclick="ApplyWorkWeekForDay"
                                        disabled="@(string.IsNullOrEmpty(dayModalSelectedWorkWeekId) || dayModalIsApplying)">
                                    @if (dayModalIsApplying)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                        <span>Applying…</span>
                                    }
                                    else
                                    {
                                        <span>Apply</span>
                                    }
                                </button>
                            </div>
                            @if (!string.IsNullOrEmpty(dayModalWorkWeekError))
                            {
                                <div class="alert alert-danger alert-sm mb-0 mt-2 py-1 px-2">
                                    <small>@dayModalWorkWeekError</small>
                                </div>
                            }
                        </div>
                    }
                }

                @* ── Modal body ────────────────────────────────────────────── *@
                <div class="modal-body day-detail-body">

                    @* Summary pill row *@
                    @if (totalItems > 0)
                    {
                        <div class="day-modal-summary-row">
                            @if (detailShifts.Count > 0)
                            {
                                <span class="day-modal-summary-pill day-modal-summary-pill--shift">@detailShifts.Count shift@(detailShifts.Count == 1 ? "" : "s")</span>
                            }
                            @if (detailAbsences.Count > 0)
                            {
                                <span class="day-modal-summary-pill day-modal-summary-pill--absence">@detailAbsences.Count absence@(detailAbsences.Count == 1 ? "" : "s")</span>
                            }
                            @if (detailReminders.Count > 0)
                            {
                                <span class="day-modal-summary-pill day-modal-summary-pill--reminder">@detailReminders.Count reminder@(detailReminders.Count == 1 ? "" : "s")</span>
                            }
                        </div>
                    }

                    @* ── Shifts section ───────────────────────────────────── *@
                    @if (detailShifts.Count > 0)
                    {
                        <div class="day-detail-section-header">
                            <span class="day-modal-section-icon day-modal-section-icon--shift">🕐</span>
                            <span class="day-detail-section-title-text">Shifts</span>
                            <span class="day-detail-section-count">@detailShifts.Count</span>
                        </div>
                        @foreach (var s in detailShifts)
                        {
                            var ds = s;
                            @* Calculate shift duration for display *@
                            var shiftDuration = ds.End - ds.Start;
                            var durationText = shiftDuration.TotalMinutes >= 60
                                ? $"{(int)shiftDuration.TotalHours}h{(shiftDuration.Minutes > 0 ? $" {shiftDuration.Minutes}m" : "")}"
                                : $"{shiftDuration.Minutes}m";

                            <div class="day-detail-shift-card" style="border-left-color: @(ds.Color ?? "#1890ff");"
                                 @onclick="(() => { if (canManageShifts) OpenEditShiftModal(ds); })"
                                 role="@(canManageShifts ? "button" : "")"
                                 title="@(canManageShifts ? "Click to edit" : "")">
                                <div class="day-detail-card-header">
                                    <span class="day-detail-worker-badge" style="color: @(ds.Color ?? "#1890ff"); background-color: @(ds.Color ?? "#1890ff")1a;">
                                        @GetShiftDisplayTitle(ds)
                                    </span>
                                    <div class="d-flex align-items-center gap-2 ms-auto">
                                        <span class="day-detail-duration-badge">@durationText</span>
                                        <span class="day-detail-time-badge">@ds.Start.ToLocalTime().ToString("t") – @ds.End.ToLocalTime().ToString("t")</span>
                                        @if (canManageShifts)
                                        {
                                            <span class="day-detail-edit-hint">Edit ›</span>
                                        }
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(ds.AssignedToUserId))
                                {
                                    <div class="day-detail-assigned">
                                        <span class="day-detail-assigned-icon">👤</span>
                                        @GetEmployeeDisplayNameById(ds.AssignedToUserId)
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(ds.Notes))
                                {
                                    <div class="day-detail-item-notes">@ds.Notes</div>
                                }
                            </div>
                        }
                    }

                    @* ── Absences section ─────────────────────────────────── *@
                    @if (detailAbsences.Count > 0)
                    {
                        <div class="day-detail-section-header @(detailShifts.Count > 0 ? "mt-4" : "")">
                            <span class="day-modal-section-icon day-modal-section-icon--absence">🛇</span>
                            <span class="day-detail-section-title-text">Absences</span>
                            <span class="day-detail-section-count">@detailAbsences.Count</span>
                        </div>
                        @foreach (var a in detailAbsences)
                        {
                            var da = a;
                            <div class="day-detail-absence-card" style="border-left-color: @(da.Color ?? "#fa8c16"); background-color: @(da.Color ?? "#fa8c16")1a;"
                                 @onclick="(() => OpenEditAbsenceModal(da))" role="button" title="Click to edit">
                                <div class="day-detail-card-header">
                                    <div class="d-flex flex-column flex-grow-1 min-w-0">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="day-detail-absence-name fw-semibold text-truncate">@GetEmployeeDisplayNameById(da.AssignedToUserId)</span>
                                            <span class="day-detail-absence-title-badge" style="background-color: @(da.Color ?? "#fa8c16")1a; color: @(da.Color ?? "#fa8c16");">@da.Title</span>
                                        </div>
                                        <div class="mt-1">
                                            @{
                                                var hasTimes = !string.IsNullOrWhiteSpace(da.StartTime) && !string.IsNullOrWhiteSpace(da.EndTime) && da.DayCount == 1;
                                                if (hasTimes && TimeOnly.TryParse(da.StartTime, CultureInfo.CurrentCulture, out var ts) && TimeOnly.TryParse(da.EndTime, CultureInfo.CurrentCulture, out var te))
                                                {
                                                    <span class="day-detail-time-badge">@ts.ToString("t", CultureInfo.CurrentCulture) – @te.ToString("t", CultureInfo.CurrentCulture)</span>
                                                }
                                                else
                                                {
                                                    <span class="day-detail-time-badge">@(da.DayCount == 1 ? "All day" : $"{da.DayCount} days")</span>
                                                }
                                            }
                                        </div>
                                    </div>
                                    <span class="day-detail-edit-hint ms-2">Edit ›</span>
                                </div>
                                @if (!string.IsNullOrEmpty(da.Notes))
                                {
                                    <div class="day-detail-item-notes">@da.Notes</div>
                                }
                            </div>
                        }
                    }

                    @* ── Reminders section ────────────────────────────────── *@
                    @if (detailReminders.Count > 0)
                    {
                        <div class="day-detail-section-header @((detailShifts.Count > 0 || detailAbsences.Count > 0) ? "mt-4" : "")">
                            <span class="day-modal-section-icon day-modal-section-icon--reminder">🔔</span>
                            <span class="day-detail-section-title-text">Reminders</span>
                            <span class="day-detail-section-count">@detailReminders.Count</span>
                        </div>
                        @foreach (var r in detailReminders)
                        {
                            var dr = r;
                            <div class="day-detail-reminder-card" style="border-left-color:@(dr.Color ?? "#ffeb3b");"
                                 @onclick="(() => OpenEditReminderModal(dr))" role="button" title="Click to edit">
                                <div class="day-detail-card-header">
                                    <span class="day-detail-reminder-title-text">@dr.Title</span>
                                    <div class="d-flex align-items-center gap-2 ms-auto">
                                        <span class="day-detail-time-badge">@dr.ReminderDateTime.ToLocalTime().ToString("t")</span>
                                        <span class="day-detail-edit-hint">Edit ›</span>
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(dr.Notes))
                                {
                                    <div class="day-detail-item-notes">@dr.Notes</div>
                                }
                            </div>
                        }
                    }

                    @* ── Empty state ──────────────────────────────────────── *@
                    @if (totalItems == 0)
                    {
                        <div class="day-detail-empty">
                            <div class="day-detail-empty-icon">📅</div>
                            <div class="day-detail-empty-title">Nothing scheduled</div>
                            <div class="day-detail-empty-text">There are no shifts, absences, or reminders for this day yet.</div>
                            <div class="d-flex justify-content-center gap-2 flex-wrap mt-3">
                                @if (canManageShifts)
                                {
                                    <button class="btn btn-primary btn-sm" @onclick="AddShiftFromDayModal">＋ Add Shift</button>
                                }
                                <button class="btn btn-warning btn-sm text-dark" @onclick="AddAbsenceFromDayModal">＋ Add Absence</button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="AddReminderFromDayModal">＋ Add Reminder</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
<CalendarEditModal State="modalState"
                   Employees="employees"
                   LinkedUsers="linkedUsers"
                   ColorChoices="ColorChoices"
                   OnClose="CloseModal"
                   OnSaveReminder="SaveReminder"
                   OnUpdateReminder="UpdateReminder"
                   OnDeleteReminder="DeleteCurrentReminder"
                   OnSaveShift="SaveShift"
                   OnUpdateShift="UpdateShift"
                   OnDeleteShift="DeleteCurrentShift"
                   OnDeleteShiftSeries="DeleteShiftSeries"
                   OnSaveAbsence="SaveAbsence"
                   OnUpdateAbsence="UpdateAbsence"
                   OnDeleteAbsence="DeleteCurrentAbsence" />

@code {
    /// <summary>
    /// View modes supported by the calendar.
    /// </summary>
    private enum ViewMode { Week, Month }

    private ViewMode view = ViewMode.Month;

    // Current user context resolved at initialization
    private string _username = string.Empty;
    private string? _managerCode;
    private string? _userId;

    // Current date used for rendering the calendar context (month or week)
    private DateOnly current = DateOnly.FromDateTime(DateTime.Today);

    // Loaded reminders for the current view
    private List<Reminder> reminders = new List<Reminder>();
    // Loaded Shifts for the current view
    private List<Shift> shifts = new List<Shift>();
    // Loaded Absences for the current view
    private List<Absence> absences = new();
    private bool isLoading = false;

    // Shift assignment / role state
    private List<User> employees = new();
    private List<User> linkedUsers = new();
    private bool canManageShifts = false;

    // Schedule selection state
    private List<Schedule> availableSchedules = new();
    private string? selectedScheduleId;
    [SupplyParameterFromQuery(Name = "scheduleId")]
    private string? QueryScheduleId { get; set; }
    // Date range used when applying a WorkWeek template from the day detail modal
    private DateOnly workWeekRangeStart;
    private DateOnly workWeekRangeEnd;

    // Event type filters
    private bool showShifts = true;
    private bool showAbsences = true;
    private bool showReminders = true;

    // Modal state
    private readonly CalendarEditModalState modalState = new();
    private bool showModal { get => modalState.ShowModal; set => modalState.ShowModal = value; }
    private DateOnly? selectedDate { get => modalState.SelectedDate; set => modalState.SelectedDate = value; }
    private ModalMode modalMode { get => modalState.ModalMode; set => modalState.ModalMode = value; }
    private string newReminderTitle { get => modalState.NewReminderTitle; set => modalState.NewReminderTitle = value; }
    private string? newReminderNotes { get => modalState.NewReminderNotes; set => modalState.NewReminderNotes = value; }
    private TimeOnly newReminderTime { get => modalState.NewReminderTime; set => modalState.NewReminderTime = value; }
    private string newReminderColor { get => modalState.NewReminderColor; set => modalState.NewReminderColor = value; }
