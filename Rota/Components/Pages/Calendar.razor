    private async Task SaveAbsence()
    {
        modalError = null;
        if (selectedDate is null) return;
        if (string.IsNullOrWhiteSpace(newAbsenceTitle)) { modalError = "Title is required"; return; }
        isBusy = true;
        try
        {
            var dayCount = Math.Max(1, Math.Min(newAbsenceDayCount, 365));
            DateTime startUtc;
            DateTime endUtc;
            if (newAbsenceIsPartDay && dayCount == 1)
            {
                // Only apply explicit times for single-day absences
                var localStart = selectedDate.Value.ToDateTime(newAbsenceStartTime, DateTimeKind.Local);
                var localEnd = selectedDate.Value.ToDateTime(newAbsenceEndTime, DateTimeKind.Local);
                startUtc = DateTime.SpecifyKind(localStart.ToUniversalTime(), DateTimeKind.Utc);
                endUtc = DateTime.SpecifyKind(localEnd.ToUniversalTime(), DateTimeKind.Utc);
                if (endUtc <= startUtc)
                {
                    modalError = "End time must be after start time";
                    return;
                }
            }
            else
            {
                startUtc = DateTime.SpecifyKind(selectedDate.Value.ToDateTime(TimeOnly.MinValue, DateTimeKind.Local).ToUniversalTime(), DateTimeKind.Utc);
                endUtc = startUtc.AddDays(dayCount);
            }
            var targetUser = GetLinkedUserById(newAbsenceForUsername) ?? GetDefaultLinkedUser();

            if (targetUser is null)
            {
                modalError = "Select a user for the absence";
                return;
            }

            var absence = new Absence
            {
                Username = _username,
                UserId = targetUser.Id,
                ManagerCode = _managerCode,
                StartDate = startUtc,
                EndDate = endUtc,
                StartTime = (newAbsenceIsPartDay && dayCount == 1) ? newAbsenceStartTime.ToString("HH:mm") : null,
                EndTime = (newAbsenceIsPartDay && dayCount == 1) ? newAbsenceEndTime.ToString("HH:mm") : null,
                DayCount = dayCount,
                Title = newAbsenceTitle,
                Notes = newAbsenceNotes,
                Color = newAbsenceColor,
                AssignedToUserId = targetUser.Id
            };
            await AbsenceService.CreateAbsenceAsync(absence);
            CloseModal();
            await LoadReminders();
        }
        catch (Exception ex) { Logger.LogError(ex, "Error saving absence"); modalError = "An error occurred."; }
        finally { isBusy = false; }
    }

    private async Task UpdateAbsence()
    {
        if (editingAbsence?.Id is null) return;
        isBusy = true;
        try
        {
            var parsed = DateTime.Parse(editAbsenceStartDateUtc, CultureInfo.InvariantCulture, DateTimeStyles.RoundtripKind);
            var startUtcParsed = DateTime.SpecifyKind(parsed, DateTimeKind.Utc);
            var dayCount = Math.Max(1, Math.Min(editAbsenceDayCount, 365));
            DateTime startUtc, endUtc;
            if (editAbsenceIsPartDay && dayCount == 1)
            {
                // Only apply explicit times for single-day absences
                var localStartDate = DateOnly.FromDateTime(startUtcParsed.ToLocalTime());
                var localStart = localStartDate.ToDateTime(editAbsenceStartTime, DateTimeKind.Local);
                var localEnd = localStartDate.ToDateTime(editAbsenceEndTime, DateTimeKind.Local);
                startUtc = DateTime.SpecifyKind(localStart.ToUniversalTime(), DateTimeKind.Utc);
                endUtc = DateTime.SpecifyKind(localEnd.ToUniversalTime(), DateTimeKind.Utc);
                if (endUtc <= startUtc)
                {
                    modalError = "End time must be after start time";
                    return;
                }
            }
            else
            {
                startUtc = startUtcParsed;
                endUtc = startUtc.AddDays(dayCount);
            }
            var targetUser = GetLinkedUserById(editAbsenceForUsername) ?? GetDefaultLinkedUser();

            if (targetUser is null)
            {
                modalError = "Select a user for the absence";
                return;
            }

            var startTimeStr = (editAbsenceIsPartDay && dayCount == 1) ? editAbsenceStartTime.ToString("HH:mm") : null;
            var endTimeStr = (editAbsenceIsPartDay && dayCount == 1) ? editAbsenceEndTime.ToString("HH:mm") : null;
            await AbsenceService.UpdateAbsenceAsync(editingAbsence.Id, _username, editAbsenceTitle, editAbsenceNotes, startUtc, endUtc, dayCount, editAbsenceColor, targetUser.Id, targetUser.Id, _managerCode, startTimeStr, endTimeStr);
            CloseModal();
            await LoadReminders();
        }
        catch (Exception ex) { Logger.LogError(ex, "Error updating absence {Id}", editingAbsence.Id); modalError = "An error occurred."; }
        finally { isBusy = false; }
    }

