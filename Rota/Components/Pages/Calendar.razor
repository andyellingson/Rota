            isBusy = true;
            var local = selectedDate.Value.ToDateTime(newReminderTime, DateTimeKind.Local);
            var utc = local.ToUniversalTime();
            var targetUser = GetLinkedUser(newReminderForUsername) ?? GetDefaultLinkedUser();

            if (targetUser is null)
            {
                modalError = "Select a user for the reminder";
                return;
            }

            var reminder = new Reminder
            {
                Username = _username,
                OwnerId = targetUser.Id,
                ManagerCode = _managerCode,
                Date = utc,
                Title = newReminderTitle,
                Notes = newReminderNotes,
                Color = newReminderColor,
                ForUsername = targetUser.Username,
                ForDisplayName = targetUser.DisplayName ?? targetUser.Username
            };
