@page "/calendar"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Globalization
@using Rota.Models
@using Rota.Services
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject NavigationManager Navigation
@inject Microsoft.Extensions.Logging.ILogger<Calendar> Logger
@inject IRemindersService RemindersService
@inject IShiftsService ShiftService
@inject IAbsencesService AbsenceService
@inject IUserService UserService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider


<div class="calendar-card card shadow-sm my-4">
    <div class="card-body">
        <div class="d-flex align-items-center mb-3">
            <div class="me-auto">
                <h4 class="mb-0">Calendar</h4>
                <small class="text-muted">View and browse your schedule</small>
            </div>

            <div class="btn-group me-2" role="group" aria-label="View mode">
                <button class="btn btn-outline-primary" @onclick="(() => SetView(ViewMode.Week))" aria-pressed="@(view == ViewMode.Week)">Week</button>
                <button class="btn btn-outline-primary" @onclick="(() => SetView(ViewMode.Month))" aria-pressed="@(view == ViewMode.Month)">Month</button>
            </div>

            <div class="btn-group" role="group" aria-label="Navigation">
                <button class="btn btn-light" @onclick="Prev">‹</button>
                <button class="btn btn-light" @onclick="Today">Today</button>
                <button class="btn btn-light" @onclick="Next">›</button>
            </div>
        </div>

        @if (view == ViewMode.Month)
        {
            <div class="calendar-month">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <strong>@current.ToString("MMMM yyyy", CultureInfo.CurrentCulture)</strong>
                    <div class="text-muted small">Week starts on @CultureInfo.CurrentCulture.DateTimeFormat.FirstDayOfWeek</div>
                </div>

                <div class="calendar-grid">
                    @foreach (var name in DayNames)
                    {
                        <div class="calendar-grid-header">@name</div>
                    }

                    @foreach (var week in GetMonthMatrix(current))
                    {
                        foreach (var day in week)
                        {
                            var other = day.Month != current.Month;
                            var isToday = day == DateOnly.FromDateTime(DateTime.Today);
                            var dayReminders = GetRemindersForDay(day)
                            .OrderBy(r => r.ReminderDateTime)
                            .ToList();
                            <div class="day-cell @(other ? "other-month" : "") @(isToday ? "today" : "")" @onclick="(() => OpenDayModal(day))">
                                <div class="day-number">@day.Day</div>
                                <div class="events events-overlay">
                                    @foreach (var shift in GetShiftsForDay(day))
                                    {
                                        var s = shift;
                                        <div class="shift-item mb-1" style="border-left-color: @(s.Color ?? "#1890ff");" @onclick:stopPropagation="true" @onclick="(() => { if (canManageShifts) OpenEditShiftModal(s); })">
                                            <div class="shift-worker-type" style="color: @(s.Color ?? "#1890ff");">@GetShiftDisplayTitle(s)</div>
                                            <div class="shift-time">@s.Start.ToLocalTime().ToString("t") – @s.End.ToLocalTime().ToString("t")</div>
                                            @if (!string.IsNullOrEmpty(s.AssignedToUserId))
                                            {
                                                <div class="shift-assigned">@GetEmployeeDisplayNameById(s.AssignedToUserId)</div>
                                            }
                                        </div>
                                    }
                                    @foreach (var absence in GetAbsencesForDay(day))
                                    {
                                        var ab = absence;
                <div class="absence-item mb-1" style="background-color: @(ab.Color ?? "#fa8c16");" @onclick:stopPropagation="true" @onclick="(() => OpenEditAbsenceModal(ab))">
                    <div class="d-flex w-100">
                        <div class="absence-left text-start text-truncate">@GetEmployeeDisplayNameById(ab.AssignedToUserId)</div>
                        <div class="absence-right text-end text-truncate">@ab.Title</div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(ab.StartTime) && !string.IsNullOrWhiteSpace(ab.EndTime) && ab.DayCount == 1)
                    {
                        if (TimeOnly.TryParse(ab.StartTime, CultureInfo.CurrentCulture, out var sst) && TimeOnly.TryParse(ab.EndTime, CultureInfo.CurrentCulture, out var eet))
                        {
                            <div class="absence-time small mt-1">@sst.ToString("t", CultureInfo.CurrentCulture) – @eet.ToString("t", CultureInfo.CurrentCulture)</div>
                        }
                    }
                </div>
                                    }
                                    @for (var i = 0; i < dayReminders.Count; i++)
                                    {
                                        var reminder = dayReminders[i];
                                        <ReminderItem Reminder="reminder"
                                                      OnEdit="OpenEditReminderModal" />
                                    }
                                </div>
                            </div>
                        }
                    }

                </div>
            </div>
        }
        else
        {
            <div class="calendar-week">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <strong>Week of @StartOfWeek(current).ToString("d", CultureInfo.CurrentCulture)</strong>
                </div>

                <div class="week-grid">
                    @foreach (var d in Enumerable.Range(0, 7).Select(i => StartOfWeek(current).AddDays(i)))
                    {
                        var isToday = d == DateOnly.FromDateTime(DateTime.Today);
                        var dayReminders = GetRemindersForDay(d)
                        .OrderBy(r => r.ReminderDateTime)
                        .ToList();
                        <div class="week-day-card card me-2">
                            <div class="card-body p-2">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-bold">@d.ToString("ddd", CultureInfo.CurrentCulture)</div>
                                        <div class="text-muted small">@d.ToString("d", CultureInfo.CurrentCulture)</div>
                                    </div>
                                    @if (isToday)
                                    {
                                        <span class="badge bg-primary">Today</span>
                                    }
                                </div>
                                <div class="mt-2 events events-overlay">
                                    @foreach (var shift in GetShiftsForDay(d))
                                    {
                                        var s = shift;
                                        <div class="shift-item mb-1" style="border-left-color: @(s.Color ?? "#1890ff");" @onclick:stopPropagation="true" @onclick="(() => { if (canManageShifts) OpenEditShiftModal(s); })">
                                            <div class="shift-worker-type" style="color: @(s.Color ?? "#1890ff");">@GetShiftDisplayTitle(s)</div>
                                            <div class="shift-time">@s.Start.ToLocalTime().ToString("t") – @s.End.ToLocalTime().ToString("t")</div>
                                            @if (!string.IsNullOrEmpty(s.AssignedToUserId))
                                            {
                                                <div class="shift-assigned">@GetEmployeeDisplayNameById(s.AssignedToUserId)</div>
                                            }
                                        </div>
                                    }
                                    @foreach (var absence in GetAbsencesForDay(d))
                                    {
                                        var ab = absence;
                <div class="absence-item mb-1" style="background-color: @(ab.Color ?? "#fa8c16");" @onclick:stopPropagation="true" @onclick="(() => OpenEditAbsenceModal(ab))">
                    <div class="d-flex w-100">
                        <div class="absence-left text-start text-truncate">@GetEmployeeDisplayNameById(ab.AssignedToUserId)</div>
                        <div class="absence-right text-end text-truncate">@ab.Title</div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(ab.StartTime) && !string.IsNullOrWhiteSpace(ab.EndTime) && ab.DayCount == 1)
                    {
                        if (TimeOnly.TryParse(ab.StartTime, CultureInfo.CurrentCulture, out var sst) && TimeOnly.TryParse(ab.EndTime, CultureInfo.CurrentCulture, out var eet))
                        {
                            <div class="absence-time small mt-1">@sst.ToString("t", CultureInfo.CurrentCulture) – @eet.ToString("t", CultureInfo.CurrentCulture)</div>
                        }
                    }
                </div>
                                    }
                                    @for (var i = 0; i < dayReminders.Count; i++)
                                    {
                                        var reminder = dayReminders[i];
                                        <ReminderItem Reminder="reminder"
                                                      OnEdit="OpenEditReminderModal" />
                                    }
                                </div>
                                <button class="btn btn-sm btn-outline-secondary w-100 mt-1" @onclick="(() => OpenAddReminderModal(d))">+ Add</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@* Day detail modal – expanded view for a single day *@
@if (showDayModal)
{
    var detailShifts = GetShiftsForDay(dayModalDate).OrderBy(s => s.Start).ToList();
    var detailReminders = GetRemindersForDay(dayModalDate).OrderBy(r => r.ReminderDateTime).ToList();
    var detailAbsences = GetAbsencesForDay(dayModalDate).ToList();

    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title mb-0">@dayModalDate.ToString("dddd", CultureInfo.CurrentCulture)</h5>
                        <small class="text-muted">@dayModalDate.ToString("d MMMM yyyy", CultureInfo.CurrentCulture)</small>
                    </div>
                    <div class="d-flex gap-2 align-items-center ms-auto">
                        @if (canManageShifts)
                        {
                            <button class="btn btn-sm btn-primary" @onclick="AddShiftFromDayModal">+ Shift</button>
                        }
                        <button class="btn btn-sm btn-warning text-dark" @onclick="AddAbsenceFromDayModal">+ Absence</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="AddReminderFromDayModal">+ Reminder</button>
                        <button type="button" class="btn-close ms-1" @onclick="CloseDayModal" aria-label="Close"></button>
                    </div>
                </div>
                <div class="modal-body day-detail-body">
                    @if (detailShifts.Count > 0)
                    {
                        <h6 class="day-detail-section-title">
                            <span class="day-detail-section-icon">🕐</span> Shifts
                        </h6>
                        @foreach (var s in detailShifts)
                        {
                            var ds = s;
                            <div class="day-detail-shift-card" style="border-left-color: @(ds.Color ?? "#1890ff");" @onclick="(() => { if (canManageShifts) OpenEditShiftModal(ds); })">
                                <div class="day-detail-card-header">
                                    <span class="day-detail-worker-badge" style="color: @(ds.Color ?? "#1890ff"); background-color: @(ds.Color ?? "#1890ff")1a;">@GetShiftDisplayTitle(ds)</span>
                                    <span class="day-detail-time-badge">@ds.Start.ToLocalTime().ToString("t") – @ds.End.ToLocalTime().ToString("t")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(ds.AssignedToUserId))
                                {
                                    <div class="day-detail-assigned">👤 @GetEmployeeDisplayNameById(ds.AssignedToUserId)</div>
                                }
                                @if (!string.IsNullOrEmpty(ds.Notes))
                                {
                                    <div class="day-detail-item-notes">@ds.Notes</div>
                                }
                            </div>
                        }
                    }
                    @if (detailAbsences.Count > 0)
                    {
                        <h6 class="day-detail-section-title @(detailShifts.Count > 0 ? "mt-4" : "")">
                            <span class="day-detail-section-icon">🛇</span> Absences
                        </h6>
                        @foreach (var a in detailAbsences)
                        {
                            var da = a;
                            <div class="day-detail-absence-card" style="border-left-color: @(da.Color ?? "#fa8c16"); background-color: @(da.Color ?? "#fa8c16")1a;" @onclick="(() => OpenEditAbsenceModal(da))">
                                <div class="day-detail-card-header d-flex flex-column">
                                    <div class="d-flex w-100 align-items-center">
                                        <span class="day-detail-absence-name text-start flex-grow-1">@GetEmployeeDisplayNameById(da.AssignedToUserId)</span>
                                        <span class="day-detail-absence-title-text text-end ms-3">@da.Title</span>
                                    </div>
                                    <div class="d-flex w-100 mt-1">
                                        @{
                                            var hasTimes = !string.IsNullOrWhiteSpace(da.StartTime) && !string.IsNullOrWhiteSpace(da.EndTime) && da.DayCount == 1;
                                            if (hasTimes && TimeOnly.TryParse(da.StartTime, CultureInfo.CurrentCulture, out var ts) && TimeOnly.TryParse(da.EndTime, CultureInfo.CurrentCulture, out var te))
                                            {
                                                <span class="day-detail-time-badge">@ts.ToString("t", CultureInfo.CurrentCulture) – @te.ToString("t", CultureInfo.CurrentCulture)</span>
                                            }
                                            else
                                            {
                                                <span class="day-detail-time-badge">@(da.DayCount == 1 ? "1 day" : $"{da.DayCount} days")</span>
                                            }
                                        }
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(da.Notes))
                                {
                                    <div class="day-detail-item-notes">@da.Notes</div>
                                }
                            </div>
                        }
                    }
                    @if (detailReminders.Count > 0)
                    {
                        <h6 class="day-detail-section-title @((detailShifts.Count > 0 || detailAbsences.Count > 0) ? "mt-4" : "")">
                            <span class="day-detail-section-icon">🔔</span> Reminders
                        </h6>
                        @foreach (var r in detailReminders)
                        {
                            var dr = r;
                            <div class="day-detail-reminder-card" style="border-left-color:@(dr.Color ?? "#ffeb3b");" @onclick="(() => OpenEditReminderModal(dr))">
                                <div class="day-detail-card-header">
                                    <span class="day-detail-reminder-title-text">@dr.Title</span>
                                    <span class="day-detail-time-badge">@dr.ReminderDateTime.ToLocalTime().ToString("t")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(dr.Notes))
                                {
                                    <div class="day-detail-item-notes">@dr.Notes</div>
                                }
                            </div>
                        }
                    }
                    @if (detailShifts.Count == 0 && detailAbsences.Count == 0 && detailReminders.Count == 0)
                    {
                        <div class="day-detail-empty">
                            <div class="day-detail-empty-icon">📅</div>
                            <div class="day-detail-empty-text">Nothing scheduled for this day.</div>
                            <div class="mt-3">
                                @if (canManageShifts)
                                {
                                    <button class="btn btn-primary btn-sm me-2" @onclick="AddShiftFromDayModal">+ Add Shift</button>
                                }
                                <button class="btn btn-warning btn-sm text-dark me-2" @onclick="AddAbsenceFromDayModal">+ Add Absence</button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="AddReminderFromDayModal">+ Add Reminder</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
<CalendarEditModal State="modalState"
                   CanManageShifts="canManageShifts"
                   Employees="employees"
                   LinkedUsers="linkedUsers"
                   ColorChoices="ColorChoices"
                   OnClose="CloseModal"
                   OnSaveReminder="SaveReminder"
                   OnUpdateReminder="UpdateReminder"
                   OnDeleteReminder="DeleteCurrentReminder"
                   OnSaveShift="SaveShift"
                   OnUpdateShift="UpdateShift"
                   OnDeleteShift="DeleteCurrentShift"
                   OnDeleteShiftSeries="DeleteShiftSeries"
                   OnSaveAbsence="SaveAbsence"
                   OnUpdateAbsence="UpdateAbsence"
                   OnDeleteAbsence="DeleteCurrentAbsence" />

@code {
    /// <summary>
    /// View modes supported by the calendar.
    /// </summary>
    private enum ViewMode { Week, Month }

    private ViewMode view = ViewMode.Month;

    // Current user context resolved at initialization
    private string _username = string.Empty;
    private string? _managerCode;
    private string? _userId;

    // Current date used for rendering the calendar context (month or week)
    private DateOnly current = DateOnly.FromDateTime(DateTime.Today);

    // Loaded reminders for the current view
    private List<Reminder> reminders = new List<Reminder>();
    // Loaded Shifts for the current view
    private List<Shift> shifts = new List<Shift>();
    // Loaded Absences for the current view
    private List<Absence> absences = new();
    private bool isLoading = false;

    // Shift assignment / role state
    private List<User> employees = new();
    private List<User> linkedUsers = new();
    private bool canManageShifts = false;

    // Modal state
    private readonly CalendarEditModalState modalState = new();
    private bool showModal { get => modalState.ShowModal; set => modalState.ShowModal = value; }
    private DateOnly? selectedDate { get => modalState.SelectedDate; set => modalState.SelectedDate = value; }
    private ModalMode modalMode { get => modalState.ModalMode; set => modalState.ModalMode = value; }
    private string newReminderTitle { get => modalState.NewReminderTitle; set => modalState.NewReminderTitle = value; }
    private string? newReminderNotes { get => modalState.NewReminderNotes; set => modalState.NewReminderNotes = value; }
    private TimeOnly newReminderTime { get => modalState.NewReminderTime; set => modalState.NewReminderTime = value; }
    private string newReminderColor { get => modalState.NewReminderColor; set => modalState.NewReminderColor = value; }
    private string newReminderForUsername { get => modalState.NewReminderForUsername; set => modalState.NewReminderForUsername = value; }
    private string? modalError { get => modalState.ModalError; set => modalState.ModalError = value; }
    private bool isBusy { get => modalState.IsBusy; set => modalState.IsBusy = value; }

    // Day detail modal state
    private bool showDayModal = false;
    private DateOnly dayModalDate;

    // Shift fields for add/edit
    private Shift? editingShift { get => modalState.EditingShift; set => modalState.EditingShift = value; }
    private string editShiftId { get => modalState.EditShiftId; set => modalState.EditShiftId = value; }
    private DateOnly editShiftDate { get => modalState.EditShiftDate; set => modalState.EditShiftDate = value; }
    private TimeOnly editShiftStartTime { get => modalState.EditShiftStartTime; set => modalState.EditShiftStartTime = value; }
    private TimeOnly editShiftEndTime { get => modalState.EditShiftEndTime; set => modalState.EditShiftEndTime = value; }
    private string editShiftTitle { get => modalState.EditShiftTitle; set => modalState.EditShiftTitle = value; }
    private string? editShiftNotes { get => modalState.EditShiftNotes; set => modalState.EditShiftNotes = value; }
    private WorkerType editShiftWorkerType { get => modalState.EditShiftWorkerType; set => modalState.EditShiftWorkerType = value; }

    private TimeOnly newShiftStartTime { get => modalState.NewShiftStartTime; set => modalState.NewShiftStartTime = value; }
    private TimeOnly newShiftEndTime { get => modalState.NewShiftEndTime; set => modalState.NewShiftEndTime = value; }
    private string newShiftTitle { get => modalState.NewShiftTitle; set => modalState.NewShiftTitle = value; }
    private string? newShiftNotes { get => modalState.NewShiftNotes; set => modalState.NewShiftNotes = value; }
    private string newShiftColor { get => modalState.NewShiftColor; set => modalState.NewShiftColor = value; }
    private WorkerType newShiftWorkerType { get => modalState.NewShiftWorkerType; set => modalState.NewShiftWorkerType = value; }
    private ShiftRecurrence newShiftRecurrence { get => modalState.NewShiftRecurrence; set => modalState.NewShiftRecurrence = value; }
    private string newShiftAssignedTo { get => modalState.NewShiftAssignedTo; set => modalState.NewShiftAssignedTo = value; }
    private string editShiftAssignedTo { get => modalState.EditShiftAssignedTo; set => modalState.EditShiftAssignedTo = value; }

    // Edit state for existing reminder
    private Reminder? editingReminder { get => modalState.EditingReminder; set => modalState.EditingReminder = value; }
    private string editReminderTitle { get => modalState.EditReminderTitle; set => modalState.EditReminderTitle = value; }
    private string? editReminderNotes { get => modalState.EditReminderNotes; set => modalState.EditReminderNotes = value; }
    private DateOnly editReminderDate { get => modalState.EditReminderDate; set => modalState.EditReminderDate = value; }
    private TimeOnly editReminderTime { get => modalState.EditReminderTime; set => modalState.EditReminderTime = value; }
    private string editReminderColor { get => modalState.EditReminderColor; set => modalState.EditReminderColor = value; }
    private string editReminderForUsername { get => modalState.EditReminderForUsername; set => modalState.EditReminderForUsername = value; }

    // Edit state for existing shift
    private string editShiftColor { get => modalState.EditShiftColor; set => modalState.EditShiftColor = value; }

    // Absence fields for add/edit
    private int newAbsenceDayCount { get => modalState.NewAbsenceDayCount; set => modalState.NewAbsenceDayCount = value; }
    private string newAbsenceTitle { get => modalState.NewAbsenceTitle; set => modalState.NewAbsenceTitle = value; }
    private string? newAbsenceNotes { get => modalState.NewAbsenceNotes; set => modalState.NewAbsenceNotes = value; }
    private string newAbsenceColor { get => modalState.NewAbsenceColor; set => modalState.NewAbsenceColor = value; }
    private string newAbsenceForUsername { get => modalState.NewAbsenceForUsername; set => modalState.NewAbsenceForUsername = value; }
    private bool newAbsenceIsPartDay { get => modalState.NewAbsenceIsPartDay; set => modalState.NewAbsenceIsPartDay = value; }
    private TimeOnly newAbsenceStartTime { get => modalState.NewAbsenceStartTime; set => modalState.NewAbsenceStartTime = value; }
    private TimeOnly newAbsenceEndTime { get => modalState.NewAbsenceEndTime; set => modalState.NewAbsenceEndTime = value; }
    private Absence? editingAbsence { get => modalState.EditingAbsence; set => modalState.EditingAbsence = value; }
    private string editAbsenceStartDateUtc { get => modalState.EditAbsenceStartDateUtc; set => modalState.EditAbsenceStartDateUtc = value; }
    private int editAbsenceDayCount { get => modalState.EditAbsenceDayCount; set => modalState.EditAbsenceDayCount = value; }
    private string editAbsenceTitle { get => modalState.EditAbsenceTitle; set => modalState.EditAbsenceTitle = value; }
    private string? editAbsenceNotes { get => modalState.EditAbsenceNotes; set => modalState.EditAbsenceNotes = value; }
    private string editAbsenceColor { get => modalState.EditAbsenceColor; set => modalState.EditAbsenceColor = value; }
    private string editAbsenceForUsername { get => modalState.EditAbsenceForUsername; set => modalState.EditAbsenceForUsername = value; }
    private bool editAbsenceIsPartDay { get => modalState.EditAbsenceIsPartDay; set => modalState.EditAbsenceIsPartDay = value; }
    private TimeOnly editAbsenceStartTime { get => modalState.EditAbsenceStartTime; set => modalState.EditAbsenceStartTime = value; }
    private TimeOnly editAbsenceEndTime { get => modalState.EditAbsenceEndTime; set => modalState.EditAbsenceEndTime = value; }

    // Preset palette: red, green, blue, orange, gray
    private readonly string[] ColorChoices = new[] { "#ff4d4f", "#52c41a", "#1890ff", "#fa8c16", "#d3d3d3" };

    // Day names for the calendar header (according to current culture)
    private string[] DayNames => CultureInfo.CurrentCulture.DateTimeFormat.AbbreviatedDayNames
        .Skip((int)CultureInfo.CurrentCulture.DateTimeFormat.FirstDayOfWeek)
        .Concat(CultureInfo.CurrentCulture.DateTimeFormat.AbbreviatedDayNames.Take((int)CultureInfo.CurrentCulture.DateTimeFormat.FirstDayOfWeek))
        .ToArray();

    /// <summary>
    /// Load reminders when the component initializes. The page-level [Authorize] attribute
    /// ensures the user is authenticated before reaching this component, so we rely on the
    /// browser's session cookie (credentials: same-origin) for API auth rather than
    /// querying HttpContextAuthenticationStateProvider, which is null during the SignalR
    /// interactive phase.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _username = user.Identity?.Name ?? string.Empty;

        if (!string.IsNullOrEmpty(_username))
        {
            var caller = await UserService.GetByUsernameAsync(_username);
            _userId = caller?.Id;

            canManageShifts = user.IsInRole(Roles.Manager) || user.IsInRole(Roles.Admin);
            if (canManageShifts)
            {
                _managerCode = caller?.ManagerCode;
                employees = await UserService.GetUsersByRoleAsync(Roles.Employee);
            }
            else if (user.IsInRole(Roles.Employee) && !string.IsNullOrEmpty(caller?.ManagerUsername))
            {
                var manager = await UserService.GetByUsernameAsync(caller.ManagerUsername);
                _managerCode = manager?.ManagerCode;
            }

            var managerUsernameForLinkedUsers = canManageShifts
                ? caller?.Username
                : caller?.ManagerUsername;

            if (!string.IsNullOrEmpty(managerUsernameForLinkedUsers))
            {
                linkedUsers = await UserService.GetLinkedUsersForManagerAsync(managerUsernameForLinkedUsers);
            }

            if (caller is not null && !linkedUsers.Any(u => u.Username == caller.Username))
            {
                linkedUsers.Add(caller);
                linkedUsers = linkedUsers
                    .OrderBy(u => u.DisplayName ?? u.Username)
                    .ThenBy(u => u.Username)
                    .ToList();
            }

            newReminderForUsername = _username;
            newAbsenceForUsername = _userId;
        }

        await LoadReminders();
    }

    /// <summary>
    /// Loads reminders and Shifts for the current view range from the server.
    /// </summary>
    private async Task LoadReminders()
    {
        isLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            // Calculate date range based on view
            DateOnly start, end;
            if (view == ViewMode.Month)
            {
                var firstOfMonth = new DateOnly(current.Year, current.Month, 1);
                start = StartOfWeek(firstOfMonth);
                var lastOfMonth = firstOfMonth.AddMonths(1).AddDays(-1);
                end = StartOfWeek(lastOfMonth).AddDays(6 * 7);
            }
            else
            {
                start = StartOfWeek(current);
                end = start.AddDays(6);
            }

            // Query a slightly broader range to avoid missing items due to UTC/local day boundaries.
            var queryStart = start.AddDays(-1);
            var queryEnd = end.AddDays(1);

            reminders = await RemindersService.GetCalendarRemindersAsync(_managerCode, _userId, queryStart, queryEnd);
            await LoadShifts(queryStart, queryEnd);
            await LoadAbsences(queryStart, queryEnd);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading calendar data");
            reminders = new List<Reminder>();
            shifts = new List<Shift>();
            absences = new();
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Gets reminders for a specific day.
    /// </summary>
    private List<Reminder> GetRemindersForDay(DateOnly day)
    {
        var startLocal = day.ToDateTime(TimeOnly.MinValue, DateTimeKind.Local);
        var endLocal = day.AddDays(1).ToDateTime(TimeOnly.MinValue, DateTimeKind.Local);

        var startUtc = startLocal.ToUniversalTime();
        var endUtc = endLocal.ToUniversalTime();

        var result = reminders
            .Where(r => r.ReminderDateTime >= startUtc && r.ReminderDateTime < endUtc)
            .ToList();

        if (result.Any())
        {
            Logger.LogInformation("Found {Count} reminder(s) for {Day}", result.Count, day);
        }

        return result;
    }

