    /// <summary>
    /// Applies the selected WorkWeek template across the user-defined date range.
    /// Iterates every day from workWeekRangeStart through workWeekRangeEnd and creates a
    /// shift for each day whose DayOfWeek matches a template entry – naturally handling
    /// partial weeks at either end of the range.
    /// </summary>
    private async Task ApplyWorkWeekForDay()
    {
        dayModalWorkWeekError = null;

        // Validate prerequisites before attempting to apply
        if (string.IsNullOrEmpty(dayModalSelectedWorkWeekId))
        {
            dayModalWorkWeekError = "Please select a WorkWeek template.";
            return;
        }

        if (string.IsNullOrEmpty(selectedScheduleId))
        {
            dayModalWorkWeekError = "No schedule is selected.";
            return;
        }

        if (string.IsNullOrEmpty(_managerCode))
        {
            dayModalWorkWeekError = "Your account does not have a manager code. Please contact support.";
            return;
        }

        if (workWeekRangeEnd < workWeekRangeStart)
        {
            dayModalWorkWeekError = "End date must be on or after the start date.";
            return;
        }

        try
        {
            dayModalIsApplying = true;

            var templateShifts = await ShiftService.GetWorkWeekTemplateShiftsAsync(dayModalSelectedWorkWeekId, _managerCode);

            if (templateShifts.Count == 0)
            {
                dayModalWorkWeekError = "No template shifts found for the selected WorkWeek.";
                return;
            }

            // Build the list of shifts to create before persisting, so a failure mid-way is easier to handle
            var toCreate = new List<Shift>();
            for (var day = workWeekRangeStart; day <= workWeekRangeEnd; day = day.AddDays(1))
            {
                foreach (var template in templateShifts)
                {
                    // Skip templates whose WorkDay does not match the current calendar day
                    if (template.WorkDay != day.DayOfWeek) continue;

                    var templateStartTime = TimeOnly.FromDateTime(template.Start);
                    var templateEndTime = TimeOnly.FromDateTime(template.End);

                    toCreate.Add(new Shift
                    {
                        Username = _username ?? string.Empty,
                        Start = day.ToDateTime(templateStartTime, DateTimeKind.Local).ToUniversalTime(),
                        End = day.ToDateTime(templateEndTime, DateTimeKind.Local).ToUniversalTime(),
                        Title = template.Title,
                        Color = template.Color,
                        Notes = template.Notes,
                        AssignedToUserId = template.AssignedToUserId,
                        ManagerCode = _managerCode,
                        ScheduleId = selectedScheduleId,
                        WorkerType = template.WorkerType,
                        WorkWeekId = null,  // Actual calendar shifts do not carry a WorkWeekId
                        WorkDay = null      // WorkDay is only meaningful on template shifts
                    });
                }
            }

            foreach (var shift in toCreate)
            {
                await ShiftService.CreateShiftAsync(shift);
            }

            // Reload calendar data so the new shifts appear immediately
            await LoadReminders();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error applying WorkWeek template over date range {Start} – {End}", workWeekRangeStart, workWeekRangeEnd);
            dayModalWorkWeekError = "An error occurred while applying the WorkWeek template. Please try again.";
        }
        finally
        {
            dayModalIsApplying = false;
        }
    }

