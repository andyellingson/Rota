@page "/account"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Rota.Services
@using Rota.Models
@using System.Globalization

@inject IUserService UserService
@inject IJSRuntime JS
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

<PageTitle>Settings – Rota</PageTitle>

<div class="account-wrapper">

    <div class="account-header">
        <h2 class="account-title">Settings</h2>
        <p class="account-subtitle">View and update your profile information.</p>
    </div>

    @if (isLoading)
    {
        <div class="text-muted small">Loading…</div>
    }
    else if (user is not null)
    {
        @* ── Profile ──────────────────────────────────────── *@
        <div class="account-section">
            <h5 class="account-section-title">👤 Profile</h5>

            <div class="account-card">
                <div class="account-field">
                    <span class="account-field-label">Username</span>
                    <span class="account-field-value">@user.Username</span>
                </div>
                <div class="account-field">
                    <span class="account-field-label">Role</span>
                    <span class="account-role-badge">@(user.Roles.Length > 0 ? user.Roles[0] : "—")</span>
                </div>
            </div>

            <div class="account-card mt-3">
                <label class="account-field-label mb-1">Display Name</label>
                <div class="d-flex gap-2 align-items-start">
                    <input class="form-control" @bind="displayNameInput" placeholder="Enter a display name" maxlength="64" />
                    <button class="btn btn-primary text-nowrap" @onclick="SaveDisplayName" disabled="@(!HasDisplayNameChanged || isBusy)">Save</button>
                </div>
                @if (!string.IsNullOrEmpty(displayNameMessage))
                {
                    <div class="account-message @(displayNameError ? "account-message-error" : "account-message-ok")">@displayNameMessage</div>
                }

                <hr class="my-3" />

                <label class="account-field-label mb-1">Occupation</label>
                <div class="d-flex gap-2 align-items-start">
                    <select class="form-select" @bind="occupationInput">
                        @foreach (var wt in Enum.GetValues(typeof(WorkerType)).Cast<WorkerType>())
                        {
                            <option value="@wt">@wt</option>
                        }
                    </select>
                    <button class="btn btn-primary text-nowrap" @onclick="SaveOccupation" disabled="@(!HasOccupationChanged || isBusy)">Save</button>
                </div>
                @if (!string.IsNullOrEmpty(occupationMessage))
                {
                    <div class="account-message @(occupationError ? "account-message-error" : "account-message-ok")">@occupationMessage</div>
                }
            </div>
        </div>

        @* ── Manager Code (managers only) ─────────────────── *@
        @if (user.Roles.Contains(Roles.Manager))
        {
            <div class="account-section">
                <h5 class="account-section-title">🏷️ Team Code</h5>
                <div class="account-card">
                    <p class="account-field-hint">Share this code with employees so they can link to your schedule.</p>
                    <div class="d-flex gap-2 align-items-center">
                        <input class="form-control manager-code-input" value="@user.ManagerCode" readonly onclick="this.select()" />
                        <button class="btn btn-outline-secondary text-nowrap" @onclick="CopyManagerCode" disabled="@codeCopied">@(codeCopied ? "Copied!" : "Copy")</button>
                    </div>
                </div>
            </div>
        }

        @* ── Manager Link (employees only) ────────────────── *@
        @if (user.Roles.Contains(Roles.Employee))
        {
            <div class="account-section">
                <h5 class="account-section-title">🔗 Manager Link</h5>
                <div class="account-card">
                    @if (!string.IsNullOrEmpty(user.ManagerUsername))
                    {
                        <div class="account-field">
                            <span class="account-field-label">Linked Manager</span>
                            <span class="account-field-value">@(linkedManagerDisplayName ?? user.ManagerUsername)</span>
                        </div>
                        @if (!showLinkForm)
                        {
                            <button class="btn btn-sm btn-outline-secondary mt-2" @onclick="(() => showLinkForm = true)">Change Manager</button>
                        }
                    }
                    else
                    {
                        <p class="account-field-hint">You are not linked to a manager yet. Enter your manager's code below.</p>
                    }

                    @if (showLinkForm || string.IsNullOrEmpty(user.ManagerUsername))
                    {
                        <div class="mt-2 d-flex gap-2 align-items-start">
                            <input class="form-control" @bind="managerCodeInput" placeholder="Paste manager code here" />
                            <button class="btn btn-primary text-nowrap" @onclick="LinkToManager" disabled="@isBusy">Link</button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(linkMessage))
                    {
                        <div class="account-message @(linkError ? "account-message-error" : "account-message-ok")">@linkMessage</div>
                    }
                </div>
            </div>
        }
        @* ── Weekly Availability ──────────────────────────── *@
        <div class="account-section availability-section">
            <h5 class="account-section-title">📅 Weekly Availability</h5>

            <div class="account-card">
                <p class="account-field-hint mb-3">Set the hours you are available to work each day of the week.</p>

                <div class="avail-week-grid">
                    @foreach (var day in _weekDays)
                    {
                        <div class="avail-day-card">
                            <div class="avail-day-header">@day.ToString()[..3]</div>

                            @* Existing availability windows for this day *@
                            @foreach (var a in availability.Where(a => a.DayOfWeek == day).OrderBy(a => a.StartTime))
                            {
                                @if (editingAvailabilityId == a.Id)
                                {
                                    @* Inline edit form — pre-populated with the item's current times *@
                                    <div class="avail-add-form">
                                        <input type="time" class="form-control form-control-sm mb-1" @bind="editStartTime" />
                                        <input type="time" class="form-control form-control-sm mb-1" @bind="editEndTime" />
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-sm btn-primary flex-grow-1" @onclick="ConfirmEditAvailability">Save</button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEditAvailability">✕</button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="avail-item">
                                        <span class="avail-time">@a.StartTime – @a.EndTime</span>
                                        <button class="avail-edit" title="Edit" @onclick="() => BeginEditAvailability(a)" @onclick:stopPropagation="true">✏</button>
                                        <button class="avail-remove" title="Remove" @onclick="() => RemoveAvailability(a)" @onclick:stopPropagation="true">✕</button>
                                    </div>
                                }
                            }

                            @* Inline add form shown when + Add is clicked for this day *@
                            @if (addingForDay == day)
                            {
                                <div class="avail-add-form">
                                    <input type="time" class="form-control form-control-sm mb-1" @bind="newStartTime" />
                                    <input type="time" class="form-control form-control-sm mb-1" @bind="newEndTime" />
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-primary flex-grow-1" @onclick="ConfirmAddAvailability">Add</button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelAddAvailability">✕</button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary avail-add-btn" @onclick="() => BeginAddAvailability(day)">+ Add</button>
                            }
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(availabilityMessage))
                {
                    <div class="account-message @(availabilityError ? "account-message-error" : "account-message-ok") mt-3">@availabilityMessage</div>
                }

                <div class="mt-3">
                    <button class="btn btn-primary" @onclick="SaveAvailability" disabled="@(!_availabilityChanged || isBusy)">
                        @(isBusy ? "Saving…" : "Save Availability")
                    </button>
                </div>
            </div>
        </div>

        @* ── Security ─────────────────────────────────────── *@
        <div class="account-section">
            <h5 class="account-section-title">🔐 Security</h5>

            <div class="account-card">
                <div class="mb-3">
                    <label class="form-label account-field-label">Current Password</label>
                    <input class="form-control" type="password" @bind="currentPassword" autocomplete="current-password" />
                </div>
                <div class="mb-3">
                    <label class="form-label account-field-label">New Password</label>
                    <input class="form-control" type="password" @bind="newPassword" autocomplete="new-password" />
                </div>
                <div class="mb-3">
                    <label class="form-label account-field-label">Confirm New Password</label>
                    <input class="form-control" type="password" @bind="confirmPassword" autocomplete="new-password" />
                </div>
                @if (!string.IsNullOrEmpty(passwordMessage))
                {
                    <div class="account-message @(passwordError ? "account-message-error" : "account-message-ok")">@passwordMessage</div>
                }
                <button class="btn btn-primary" @onclick="ChangePassword" disabled="@(!HasPasswordInput || isBusy)">Change Password</button>
            </div>
        </div>
    }
</div>

@code {
    // Days ordered from the culture's first day of week (used by the availability grid)
    private static readonly DayOfWeek[] _weekDays = Enumerable.Range(0, 7)
        .Select(i => (DayOfWeek)(((int)CultureInfo.CurrentCulture.DateTimeFormat.FirstDayOfWeek + i) % 7))
        .ToArray();

    private Rota.Services.User? user;
    private bool isLoading = true;
    private bool isBusy = false;

    private string displayNameInput = string.Empty;
    private string? displayNameMessage;
    private bool displayNameError;

    private WorkerType occupationInput = WorkerType.General;
    private string? occupationMessage;
    private bool occupationError;

    private string currentPassword = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private string? passwordMessage;
    private bool passwordError;

    // Manager code
    private bool codeCopied = false;

    // Employee manager-link
    private string? linkedManagerDisplayName;
    private string managerCodeInput = string.Empty;
    private string? linkMessage;
    private bool linkError;
    private bool showLinkForm = false;

    // ── Availability ─────────────────────────────────────────────────────
    // Working copy of the user's availability list; changes are applied locally
    // and only persisted when the user clicks Save Availability.
    private List<UserAvailability> availability = new();
    private DayOfWeek? addingForDay = null;
    private TimeOnly newStartTime = new TimeOnly(9, 0);
    private TimeOnly newEndTime = new TimeOnly(17, 0);
    // Tracks which availability item is currently open in the inline edit form
    private string? editingAvailabilityId = null;
    private TimeOnly editStartTime = new TimeOnly(9, 0);
    private TimeOnly editEndTime = new TimeOnly(17, 0);
    // Set to true whenever the availability list is mutated; reset after a successful save
    private bool _availabilityChanged = false;
    private string? availabilityMessage;
    private bool availabilityError;

    // ── Dirty-state computed properties ──────────────────────────────────

    /// <summary>True when the display name input differs from the saved value.</summary>
    private bool HasDisplayNameChanged =>
        displayNameInput.Trim() != (user?.DisplayName ?? string.Empty);

    /// <summary>True when the occupation dropdown differs from the saved value.</summary>
    private bool HasOccupationChanged =>
        occupationInput != (user?.Occupation ?? WorkerType.General);

    /// <summary>True when all three password fields contain text.</summary>
    private bool HasPasswordInput =>
        !string.IsNullOrWhiteSpace(currentPassword) &&
        !string.IsNullOrWhiteSpace(newPassword) &&
        !string.IsNullOrWhiteSpace(confirmPassword);

    protected override async Task OnInitializedAsync()
    {
        var username = HttpContextAccessor.HttpContext?.User.Identity?.Name;
        if (username is not null)
        {
            user = await UserService.GetByUsernameAsync(username);
            displayNameInput = user?.DisplayName ?? string.Empty;
            occupationInput = user?.Occupation ?? WorkerType.General;

            // Load the user's saved availability into the working copy
            availability = user?.Availability.Select(a => new UserAvailability
            {
                Id = a.Id,
                DayOfWeek = a.DayOfWeek,
                StartTime = a.StartTime,
                EndTime = a.EndTime
            }).ToList() ?? new();

            if (user?.ManagerUsername is not null)
            {
                var mgr = await UserService.GetByUsernameAsync(user.ManagerUsername);
                linkedManagerDisplayName = mgr?.DisplayName ?? user.ManagerUsername;
            }
        }
        isLoading = false;
    }

    private async Task CopyManagerCode()
    {
        if (string.IsNullOrEmpty(user?.ManagerCode)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", user.ManagerCode);
            codeCopied = true;
            StateHasChanged();
            await Task.Delay(2000);
            codeCopied = false;
        }
        catch
        {
            // Clipboard API unavailable — the readonly input lets users copy manually
        }
    }

    private async Task LinkToManager()
    {
        if (user is null) return;
        linkMessage = null;
        if (string.IsNullOrWhiteSpace(managerCodeInput))
        {
            linkMessage = "Please enter a manager code.";
            linkError = true;
            return;
        }
        isBusy = true;
        try
        {
            var ok = await UserService.LinkToManagerAsync(user.Username, managerCodeInput.Trim());
            if (ok)
            {
                user = await UserService.GetByUsernameAsync(user.Username) ?? user;
                if (user.ManagerUsername is not null)
                {
                    var mgr = await UserService.GetByUsernameAsync(user.ManagerUsername);
                    linkedManagerDisplayName = mgr?.DisplayName ?? user.ManagerUsername;
                }
                managerCodeInput = string.Empty;
                showLinkForm = false;
                linkMessage = "Successfully linked to manager.";
                linkError = false;
            }
            else
            {
                linkMessage = "Manager code not found. Please check and try again.";
                linkError = true;
            }
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task SaveOccupation()
    {
        if (user is null) return;
        occupationMessage = null;
        isBusy = true;
        try
        {
            var ok = await UserService.UpdateOccupationAsync(user.Username, occupationInput);
            if (ok)
            {
                user.Occupation = occupationInput;
                occupationMessage = "Occupation updated.";
                occupationError = false;
            }
            else
            {
                occupationMessage = "Could not update occupation. Please try again.";
                occupationError = true;
            }
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task SaveDisplayName()
    {
        if (user is null) return;
        displayNameMessage = null;
        isBusy = true;
        try
        {
            var trimmed = string.IsNullOrWhiteSpace(displayNameInput) ? null : displayNameInput.Trim();
            var ok = await UserService.UpdateDisplayNameAsync(user.Username, trimmed);
            if (ok)
            {
                user.DisplayName = trimmed;
                displayNameMessage = "Display name updated.";
                displayNameError = false;
            }
            else
            {
                displayNameMessage = "Could not update display name. Please try again.";
                displayNameError = true;
            }
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ChangePassword()
    {
        if (user is null) return;
        passwordMessage = null;

        if (string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword))
        {
            passwordMessage = "All password fields are required.";
            passwordError = true;
            return;
        }
        if (newPassword != confirmPassword)
        {
            passwordMessage = "New passwords do not match.";
            passwordError = true;
            return;
        }
        if (newPassword.Length < 6)
        {
            passwordMessage = "New password must be at least 6 characters.";
            passwordError = true;
            return;
        }

        isBusy = true;
        try
        {
            var ok = await UserService.UpdatePasswordAsync(user.Username, currentPassword, newPassword);
            if (ok)
            {
                currentPassword = string.Empty;
                newPassword = string.Empty;
                confirmPassword = string.Empty;
                passwordMessage = "Password changed successfully.";
                passwordError = false;
            }
            else
            {
                passwordMessage = "Current password is incorrect.";
                passwordError = true;
            }
        }
        finally
        {
            isBusy = false;
        }
    }

    // ── Availability methods ──────────────────────────────────────────────

    /// <summary>
    /// Opens the inline add form for the given day, resetting time inputs to defaults.
    /// Closes any open edit form first.
    /// </summary>
    private void BeginAddAvailability(DayOfWeek day)
    {
        editingAvailabilityId = null;
        addingForDay = day;
        newStartTime = new TimeOnly(9, 0);
        newEndTime = new TimeOnly(17, 0);
    }

    /// <summary>
    /// Opens the inline edit form for an existing availability item,
    /// pre-populating the time inputs from the item's stored values.
    /// Closes any open add form first.
    /// </summary>
    private void BeginEditAvailability(UserAvailability item)
    {
        addingForDay = null;
        editingAvailabilityId = item.Id;
        // Parse stored "HH:mm" strings back to TimeOnly for the time inputs
        editStartTime = TimeOnly.TryParse(item.StartTime, out var s) ? s : new TimeOnly(9, 0);
        editEndTime = TimeOnly.TryParse(item.EndTime, out var e) ? e : new TimeOnly(17, 0);
    }

    /// <summary>
    /// Dismisses the inline edit form without saving changes.
    /// </summary>
    private void CancelEditAvailability()
    {
        editingAvailabilityId = null;
    }

    /// <summary>
    /// Validates the edited times and updates the availability item in the working list.
    /// </summary>
    private void ConfirmEditAvailability()
    {
        if (editingAvailabilityId is null) return;

        if (editStartTime >= editEndTime)
        {
            availabilityMessage = "Start time must be before end time.";
            availabilityError = true;
            return;
        }

        var item = availability.FirstOrDefault(a => a.Id == editingAvailabilityId);
        if (item is not null)
        {
            item.StartTime = editStartTime.ToString("HH:mm");
            item.EndTime = editEndTime.ToString("HH:mm");
            _availabilityChanged = true;
        }

        availabilityMessage = null;
        editingAvailabilityId = null;
    }

    /// <summary>
    /// Dismisses the inline add form without adding anything.
    /// </summary>
    private void CancelAddAvailability()
    {
        addingForDay = null;
    }

    /// <summary>
    /// Validates the time inputs and appends a new availability window to the working list.
    /// </summary>
    private void ConfirmAddAvailability()
    {
        if (addingForDay is null) return;

        // Validate that start is before end
        if (newStartTime >= newEndTime)
        {
            availabilityMessage = "Start time must be before end time.";
            availabilityError = true;
            return;
        }

        availability.Add(new UserAvailability
        {
            DayOfWeek = addingForDay.Value,
            StartTime = newStartTime.ToString("HH:mm"),
            EndTime = newEndTime.ToString("HH:mm")
        });

        _availabilityChanged = true;
        availabilityMessage = null;
        addingForDay = null;
    }

    /// <summary>
    /// Removes an availability window from the working list by its client-side Id.
    /// </summary>
    private void RemoveAvailability(UserAvailability item)
    {
        availability.RemoveAll(a => a.Id == item.Id);
        _availabilityChanged = true;
    }

    /// <summary>
    /// Persists the current working availability list to the user document in MongoDB.
    /// </summary>
    private async Task SaveAvailability()
    {
        if (user is null) return;
        availabilityMessage = null;
        isBusy = true;
        try
        {
            var ok = await UserService.UpdateAvailabilityAsync(user.Username, availability);
            if (ok)
            {
                // Keep the in-memory user document in sync
                user.Availability = availability
                    .Select(a => new UserAvailability
                    {
                        Id = a.Id,
                        DayOfWeek = a.DayOfWeek,
                        StartTime = a.StartTime,
                        EndTime = a.EndTime
                    }).ToList();
                _availabilityChanged = false;
                availabilityMessage = "Availability saved.";
                availabilityError = false;
            }
            else
            {
                availabilityMessage = "Could not save availability. Please try again.";
                availabilityError = true;
            }
        }
        finally
        {
            isBusy = false;
        }
    }
}
