@page "/schedules"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Rota.Models
@using Rota.Services
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Manager,Admin")]
@inject ISchedulesService SchedulesService
@inject IUserService UserService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject Microsoft.Extensions.Logging.ILogger<Schedules> Logger

<div class="container my-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex align-items-center mb-4">
                <div class="me-auto">
                    <h4 class="mb-0">Manage Schedules</h4>
                    <small class="text-muted">Create and manage your work schedules</small>
                </div>
                <button class="btn btn-primary" @onclick="OpenCreateModal">
                    <span class="me-1">+</span> New Schedule
                </button>
            </div>

            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (schedules.Count == 0)
            {
                <div class="alert alert-info">
                    <strong>No schedules yet.</strong> Create your first schedule to get started.
                </div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var schedule in schedules)
                    {
                        <div class="list-group-item @(schedule.IsDefault ? "list-group-item-primary" : "")">
                            <div class="d-flex w-100 justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <h5 class="mb-1">
                                        @schedule.Name
                                        @if (schedule.IsDefault)
                                        {
                                            <span class="badge bg-primary ms-2">Default</span>
                                        }
                                    </h5>
                                    @if (!string.IsNullOrEmpty(schedule.Description))
                                    {
                                        <p class="mb-1 text-muted">@schedule.Description</p>
                                    }
                                    <small class="text-muted">Created @schedule.CreatedAt.ToLocalTime().ToString("g")</small>
                                </div>
                                <div class="btn-group ms-3">
                                    @if (!schedule.IsDefault)
                                    {
                                        <button class="btn btn-sm btn-outline-primary" @onclick="(() => SetAsDefault(schedule))">
                                            Set as Default
                                        </button>
                                    }
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="(() => ViewInCalendar(schedule))">
                                        View Calendar
                                    </button>
                                    <button class="btn btn-sm btn-outline-warning" @onclick="(() => OpenEditModal(schedule))">
                                        Edit
                                    </button>
                                    @if (schedules.Count > 1)
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="(() => OpenDeleteConfirm(schedule))">
                                            Delete
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@* Create/Edit Schedule Modal *@
@if (showModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingSchedule == null ? "Create New Schedule" : "Edit Schedule")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger">@modalError</div>
                    }
                    
                    <div class="mb-3">
                        <label class="form-label">Schedule Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="scheduleName" placeholder="e.g. April 2026 Schedule" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Description (optional)</label>
                        <textarea class="form-control" rows="3" @bind="scheduleDescription" placeholder="Add a description for this schedule"></textarea>
                    </div>

                    @if (editingSchedule == null || !editingSchedule.IsDefault)
                    {
                        <div class="mb-3 form-check">
                            <input class="form-check-input" type="checkbox" id="setAsDefault" @bind="setAsDefault" />
                            <label class="form-check-label" for="setAsDefault">
                                Set as default schedule
                            </label>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal" disabled="@isBusy">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveSchedule" disabled="@isBusy">
                        @(isBusy ? "Saving..." : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Delete Confirmation Modal *@
@if (showDeleteConfirm && scheduleToDelete != null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Delete Schedule</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDeleteConfirm" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger">@modalError</div>
                    }
                    <p>Are you sure you want to delete the schedule <strong>@scheduleToDelete.Name</strong>?</p>
                    <p class="text-danger mb-0">
                        <strong>Warning:</strong> All shifts, absences, and reminders associated with this schedule will remain but will no longer be grouped under this schedule.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDeleteConfirm" disabled="@isBusy">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteSchedule" disabled="@isBusy">
                        @(isBusy ? "Deleting..." : "Delete Schedule")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Schedule> schedules = new();
    private bool isLoading = false;
    private string? _userId;
    private string? _username;
    private string? _managerCode;

    // Modal state
    private bool showModal = false;
    private bool showDeleteConfirm = false;
    private Schedule? editingSchedule;
    private Schedule? scheduleToDelete;
    private string scheduleName = string.Empty;
    private string? scheduleDescription;
    private bool setAsDefault = false;
    private string? modalError;
    private bool isBusy = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _username = user.Identity?.Name ?? string.Empty;

        if (!string.IsNullOrEmpty(_username))
        {
            var caller = await UserService.GetByUsernameAsync(_username);
            _userId = caller?.Id;
            _managerCode = caller?.ManagerCode;
        }

        await LoadSchedules();
    }

    private async Task LoadSchedules()
    {
        if (string.IsNullOrEmpty(_userId))
        {
            return;
        }

        isLoading = true;
        try
        {
            schedules = await SchedulesService.GetSchedulesForManagerAsync(_userId);
            
            // Ensure at least one schedule exists
            if (schedules.Count == 0 && !string.IsNullOrEmpty(_username))
            {
                var defaultSchedule = await SchedulesService.GetOrCreateDefaultScheduleAsync(_userId, _username, _managerCode);
                schedules.Add(defaultSchedule);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading schedules");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreateModal()
    {
        editingSchedule = null;
        scheduleName = string.Empty;
        scheduleDescription = null;
        setAsDefault = false;
        modalError = null;
        showModal = true;
    }

    private void OpenEditModal(Schedule schedule)
    {
        editingSchedule = schedule;
        scheduleName = schedule.Name;
        scheduleDescription = schedule.Description;
        setAsDefault = schedule.IsDefault;
        modalError = null;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingSchedule = null;
        modalError = null;
    }

    private async Task SaveSchedule()
    {
        modalError = null;

        if (string.IsNullOrWhiteSpace(scheduleName))
        {
            modalError = "Schedule name is required.";
            return;
        }

        if (string.IsNullOrEmpty(_userId) || string.IsNullOrEmpty(_username))
        {
            modalError = "User information is missing.";
            return;
        }

        isBusy = true;
        try
        {
            if (editingSchedule == null)
            {
                // Create new schedule
                var newSchedule = new Schedule
                {
                    Name = scheduleName.Trim(),
                    Description = scheduleDescription?.Trim(),
                    ManagerId = _userId,
                    ManagerUsername = _username,
                    ManagerCode = _managerCode,
                    IsDefault = setAsDefault
                };

                await SchedulesService.CreateScheduleAsync(newSchedule);
            }
            else
            {
                // Update existing schedule
                await SchedulesService.UpdateScheduleAsync(
                    editingSchedule.Id!,
                    _userId,
                    scheduleName.Trim(),
                    scheduleDescription?.Trim(),
                    setAsDefault
                );
            }

            CloseModal();
            await LoadSchedules();
        }
        catch (InvalidOperationException ex)
        {
            modalError = ex.Message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving schedule");
            modalError = "An error occurred while saving the schedule. Please try again.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private void OpenDeleteConfirm(Schedule schedule)
    {
        scheduleToDelete = schedule;
        modalError = null;
        showDeleteConfirm = true;
    }

    private void CloseDeleteConfirm()
    {
        showDeleteConfirm = false;
        scheduleToDelete = null;
        modalError = null;
    }

    private async Task DeleteSchedule()
    {
        if (scheduleToDelete == null || string.IsNullOrEmpty(_userId))
        {
            return;
        }

        isBusy = true;
        modalError = null;
        try
        {
            await SchedulesService.DeleteScheduleAsync(scheduleToDelete.Id!, _userId);
            CloseDeleteConfirm();
            await LoadSchedules();
        }
        catch (InvalidOperationException ex)
        {
            modalError = ex.Message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting schedule");
            modalError = "An error occurred while deleting the schedule. Please try again.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task SetAsDefault(Schedule schedule)
    {
        if (string.IsNullOrEmpty(_userId))
        {
            return;
        }

        try
        {
            await SchedulesService.SetDefaultScheduleAsync(schedule.Id!, _userId);
            await LoadSchedules();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error setting default schedule");
        }
    }

    private void ViewInCalendar(Schedule schedule)
    {
        Navigation.NavigateTo($"/calendar?scheduleId={schedule.Id}");
    }
}
